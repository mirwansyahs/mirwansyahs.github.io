---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
    title="Emoji & Text Style - Irwansyah Tools"
    description="Ubah teks jadi style unik seperti bubble, monospace, fullwidth, dan tambahkan emoji otomatis."
    canonicalPath="/tools/emoji-text-style"
>
    <section
        class="rounded-3xl border border-slate-200 bg-white p-4 shadow-sm md:p-5"
    >
        <h1 class="text-2xl font-black text-slate-900 md:text-3xl">
            Emoji / Text Style
        </h1>
        <p class="mt-1 text-sm text-slate-600">
            Styling teks untuk bio, caption, judul, dan konten sosial media.
        </p>

        <label class="mt-4 block text-sm">
            <span class="mb-1 block font-semibold text-slate-700"
                >Input Teks</span
            >
            <textarea
                id="styleInput"
                class="h-40 w-full rounded-2xl border border-slate-300 p-3 text-sm"
                placeholder="Contoh: promo spesial minggu ini"></textarea>
        </label>

        <div class="mt-3 grid gap-3 md:grid-cols-3">
            <label class="block text-sm">
                <span class="mb-1 block font-semibold text-slate-700"
                    >Style</span
                >
                <select
                    id="styleType"
                    class="w-full rounded-2xl border border-slate-300 p-2"
                >
                    <option value="bold">Bold Unicode</option>
                    <option value="bubble">Bubble</option>
                    <option value="mono">Monospace</option>
                    <option value="fullwidth">Fullwidth</option>
                    <option value="smallcaps">Small Caps</option>
                </select>
            </label>
            <label class="block text-sm">
                <span class="mb-1 block font-semibold text-slate-700"
                    >Tema Emoji</span
                >
                <select
                    id="emojiTheme"
                    class="w-full rounded-2xl border border-slate-300 p-2"
                >
                    <option value="spark">Spark</option>
                    <option value="party">Party</option>
                    <option value="business">Business</option>
                    <option value="ramadhan">Ramadhan</option>
                    <option value="newyear">Tahun Baru</option>
                </select>
            </label>
            <label class="block text-sm">
                <span class="mb-1 block font-semibold text-slate-700"
                    >Variasi</span
                >
                <input
                    id="styleCount"
                    type="number"
                    min="1"
                    max="12"
                    value="5"
                    class="w-full rounded-2xl border border-slate-300 p-2"
                />
            </label>
        </div>

        <div class="mt-4 flex flex-wrap gap-2">
            <button
                id="styleGenerateBtn"
                class="rounded-xl bg-teal-600 px-4 py-2 text-sm font-semibold text-white hover:bg-teal-700"
                >Generate Style</button
            >
            <button
                id="styleCopyBtn"
                class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100"
                >Copy Output</button
            >
        </div>

        <textarea
            id="styleOutput"
            class="mt-3 h-72 w-full rounded-2xl border border-slate-300 p-3 text-sm"
            readonly></textarea>
        <p id="styleMessage" class="mt-2 text-sm text-slate-600"></p>
    </section>

    <script>
        const inputEl = document.getElementById(
            "styleInput",
        ) as HTMLTextAreaElement | null;
        const styleEl = document.getElementById(
            "styleType",
        ) as HTMLSelectElement | null;
        const themeEl = document.getElementById(
            "emojiTheme",
        ) as HTMLSelectElement | null;
        const countEl = document.getElementById(
            "styleCount",
        ) as HTMLInputElement | null;
        const outputEl = document.getElementById(
            "styleOutput",
        ) as HTMLTextAreaElement | null;
        const messageEl = document.getElementById(
            "styleMessage",
        ) as HTMLParagraphElement | null;

        const themes: Record<string, string[]> = {
            spark: ["✨", "🌟", "💫"],
            party: ["🎉", "🔥", "🚀"],
            business: ["📈", "💼", "✅"],
            ramadhan: ["🌙", "🕌", "🤲"],
            newyear: ["🎊", "🥳", "🎆"],
        };

        const mapByOffset = (
            input: string,
            baseUpper: number,
            baseLower: number,
        ) => {
            let out = "";
            for (const ch of input) {
                const code = ch.charCodeAt(0);
                if (code >= 65 && code <= 90) {
                    out += String.fromCodePoint(baseUpper + (code - 65));
                } else if (code >= 97 && code <= 122) {
                    out += String.fromCodePoint(baseLower + (code - 97));
                } else if (code >= 48 && code <= 57) {
                    out += String.fromCodePoint(0x1d7ce + (code - 48));
                } else {
                    out += ch;
                }
            }
            return out;
        };

        const toStyle = (text: string, style: string) => {
            if (style === "bold") return mapByOffset(text, 0x1d400, 0x1d41a);
            if (style === "bubble") return mapByOffset(text, 0x24b6, 0x24d0);
            if (style === "mono") return mapByOffset(text, 0x1d670, 0x1d68a);
            if (style === "fullwidth") {
                return text
                    .split("")
                    .map((ch) => {
                        const code = ch.charCodeAt(0);
                        if (code === 32) return "　";
                        if (code >= 33 && code <= 126) {
                            return String.fromCharCode(code + 65248);
                        }
                        return ch;
                    })
                    .join("");
            }
            if (style === "smallcaps") {
                return text
                    .replace(/a/g, "ᴀ")
                    .replace(/b/g, "ʙ")
                    .replace(/c/g, "ᴄ")
                    .replace(/d/g, "ᴅ")
                    .replace(/e/g, "ᴇ")
                    .replace(/f/g, "ғ")
                    .replace(/g/g, "ɢ")
                    .replace(/h/g, "ʜ")
                    .replace(/i/g, "ɪ")
                    .replace(/j/g, "ᴊ")
                    .replace(/k/g, "ᴋ")
                    .replace(/l/g, "ʟ")
                    .replace(/m/g, "ᴍ")
                    .replace(/n/g, "ɴ")
                    .replace(/o/g, "ᴏ")
                    .replace(/p/g, "ᴘ")
                    .replace(/q/g, "ǫ")
                    .replace(/r/g, "ʀ")
                    .replace(/s/g, "s")
                    .replace(/t/g, "ᴛ")
                    .replace(/u/g, "ᴜ")
                    .replace(/v/g, "ᴠ")
                    .replace(/w/g, "ᴡ")
                    .replace(/x/g, "x")
                    .replace(/y/g, "ʏ")
                    .replace(/z/g, "ᴢ");
            }
            return text;
        };

        document
            .getElementById("styleGenerateBtn")
            ?.addEventListener("click", () => {
                const input = (inputEl?.value ?? "").trim();
                if (!input) {
                    if (messageEl)
                        messageEl.textContent = "Input teks wajib diisi.";
                    return;
                }

                const style = styleEl?.value ?? "bold";
                const theme = themeEl?.value ?? "spark";
                const emojis = themes[theme] ?? themes.spark;
                const count = Math.min(
                    12,
                    Math.max(1, Number(countEl?.value ?? 5)),
                );

                const variants = Array.from({ length: count }, (_, i) => {
                    const left = emojis[i % emojis.length];
                    const right = emojis[(i + 1) % emojis.length];
                    const styled = toStyle(input, style);
                    return `${i + 1}. ${left} ${styled} ${right}`;
                });

                if (outputEl) outputEl.value = variants.join("\n");
                if (messageEl)
                    messageEl.textContent = `${count} style teks berhasil dibuat.`;
            });

        document
            .getElementById("styleCopyBtn")
            ?.addEventListener("click", async () => {
                const text = outputEl?.value ?? "";
                if (!text) return;
                await navigator.clipboard.writeText(text);
                if (messageEl) messageEl.textContent = "Output style tersalin.";
            });
    </script>
</BaseLayout>
