---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
    title="JSON Formatter and Validator - Irwansyah Tools"
    description="Format, beautify, minify, dan validasi JSON secara instan di browser. Cocok untuk debugging API response dan payload request."
    canonicalPath="/tools/json-formatter-validator"
>
    <section
        class="rounded-3xl border border-slate-200 bg-white p-4 shadow-sm md:p-5"
    >
        <h1 class="text-2xl font-black text-slate-900 md:text-3xl">
            JSON Formatter and Validator
        </h1>
        <p class="mt-1 text-sm text-slate-600">
            Paste JSON untuk validasi, beautify, atau minify.
        </p>

        <div class="mt-3 grid gap-3 md:grid-cols-2">
            <label class="block">
                <span class="mb-2 block text-sm font-semibold text-slate-700"
                    >Input JSON</span
                >
                <textarea
                    id="jsonInput"
                    class="h-44 w-full rounded-2xl border border-slate-300 p-3 font-mono text-sm md:h-56 lg:h-[36vh]"
                    placeholder='{"name":"Irwan","active":true}'></textarea>
            </label>
            <label class="block">
                <span class="mb-2 block text-sm font-semibold text-slate-700"
                    >Output</span
                >
                <textarea
                    id="jsonOutput"
                    class="h-44 w-full rounded-2xl border border-slate-300 p-3 font-mono text-sm md:h-56 lg:h-[36vh]"
                    readonly></textarea>
            </label>
        </div>

        <div class="mt-3 flex flex-wrap gap-2">
            <button
                id="jsonValidateBtn"
                class="rounded-xl bg-teal-600 px-4 py-2 text-sm font-semibold text-white hover:bg-teal-700"
                >Validate</button
            >
            <button
                id="jsonBeautifyBtn"
                class="rounded-xl bg-sky-600 px-4 py-2 text-sm font-semibold text-white hover:bg-sky-700"
                >Beautify</button
            >
            <button
                id="jsonMinifyBtn"
                class="rounded-xl bg-amber-500 px-4 py-2 text-sm font-semibold text-slate-900 hover:bg-amber-400"
                >Minify</button
            >
            <button
                id="jsonCopyBtn"
                class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100"
                >Copy Output</button
            >
        </div>

        <p id="jsonMessage" class="mt-3 text-sm text-slate-600"></p>
    </section>

    <script>
        const inputEl = document.getElementById(
            "jsonInput",
        ) as HTMLTextAreaElement | null;
        const outputEl = document.getElementById(
            "jsonOutput",
        ) as HTMLTextAreaElement | null;
        const messageEl = document.getElementById(
            "jsonMessage",
        ) as HTMLParagraphElement | null;

        const parseJson = () => JSON.parse(inputEl?.value ?? "");

        document
            .getElementById("jsonValidateBtn")
            ?.addEventListener("click", () => {
                try {
                    parseJson();
                    if (messageEl) messageEl.textContent = "JSON valid.";
                } catch (error) {
                    if (messageEl)
                        messageEl.textContent = `JSON tidak valid: ${error instanceof Error ? error.message : "Unknown error"}`;
                }
            });

        document
            .getElementById("jsonBeautifyBtn")
            ?.addEventListener("click", () => {
                try {
                    const parsed = parseJson();
                    if (outputEl)
                        outputEl.value = JSON.stringify(parsed, null, 2);
                    if (messageEl)
                        messageEl.textContent = "JSON berhasil di-beautify.";
                } catch (error) {
                    if (messageEl)
                        messageEl.textContent = `Beautify gagal: ${error instanceof Error ? error.message : "Unknown error"}`;
                }
            });

        document
            .getElementById("jsonMinifyBtn")
            ?.addEventListener("click", () => {
                try {
                    const parsed = parseJson();
                    if (outputEl) outputEl.value = JSON.stringify(parsed);
                    if (messageEl)
                        messageEl.textContent = "JSON berhasil di-minify.";
                } catch (error) {
                    if (messageEl)
                        messageEl.textContent = `Minify gagal: ${error instanceof Error ? error.message : "Unknown error"}`;
                }
            });

        document
            .getElementById("jsonCopyBtn")
            ?.addEventListener("click", async () => {
                const value = outputEl?.value ?? "";
                if (!value) return;
                await navigator.clipboard.writeText(value);
                if (messageEl)
                    messageEl.textContent = "Output tersalin ke clipboard.";
            });
    </script>
</BaseLayout>
