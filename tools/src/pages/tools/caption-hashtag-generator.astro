---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
    title="Caption + Hashtag Generator - Irwansyah Tools"
    description="Generate caption dan hashtag otomatis untuk Instagram, TikTok, X, dan LinkedIn."
    canonicalPath="/tools/caption-hashtag-generator"
>
    <section
        class="rounded-3xl border border-slate-200 bg-white p-4 shadow-sm md:p-5"
    >
        <h1 class="text-2xl font-black text-slate-900 md:text-3xl">
            Caption + Hashtag Generator
        </h1>
        <p class="mt-1 text-sm text-slate-600">
            Buat caption lengkap dengan hashtag relevan dalam sekali generate.
        </p>

        <div class="mt-4 grid gap-3 md:grid-cols-2">
            <label class="block text-sm md:col-span-2">
                <span class="mb-1 block font-semibold text-slate-700"
                    >Topik</span
                >
                <input
                    id="topic"
                    type="text"
                    placeholder="Contoh: promo bukber keluarga"
                    class="w-full rounded-2xl border border-slate-300 p-2"
                />
            </label>
            <label class="block text-sm">
                <span class="mb-1 block font-semibold text-slate-700"
                    >Platform</span
                >
                <select
                    id="platform"
                    class="w-full rounded-2xl border border-slate-300 p-2"
                >
                    <option value="Instagram">Instagram</option>
                    <option value="TikTok">TikTok</option>
                    <option value="X">X (Twitter)</option>
                    <option value="LinkedIn">LinkedIn</option>
                </select>
            </label>
            <label class="block text-sm">
                <span class="mb-1 block font-semibold text-slate-700">Tone</span
                >
                <select
                    id="tone"
                    class="w-full rounded-2xl border border-slate-300 p-2"
                >
                    <option value="friendly">Friendly</option>
                    <option value="promo">Promo</option>
                    <option value="professional">Professional</option>
                    <option value="casual">Casual</option>
                </select>
            </label>
        </div>

        <div class="mt-3 grid gap-3 md:grid-cols-3">
            <label class="block text-sm">
                <span class="mb-1 block font-semibold text-slate-700"
                    >Audiens</span
                >
                <input
                    id="audience"
                    type="text"
                    placeholder="Contoh: mahasiswa"
                    class="w-full rounded-2xl border border-slate-300 p-2"
                />
            </label>
            <label class="block text-sm">
                <span class="mb-1 block font-semibold text-slate-700"
                    >Jumlah Output</span
                >
                <input
                    id="count"
                    type="number"
                    min="1"
                    max="20"
                    value="6"
                    class="w-full rounded-2xl border border-slate-300 p-2"
                />
            </label>
            <label
                class="mt-6 inline-flex items-center gap-2 text-sm text-slate-700 md:mt-7"
            >
                <input id="withEmoji" type="checkbox" class="h-4 w-4" checked />
                Tambahkan emoji
            </label>
        </div>

        <label class="mt-3 block text-sm">
            <span class="mb-1 block font-semibold text-slate-700"
                >CTA (Opsional)</span
            >
            <input
                id="cta"
                type="text"
                placeholder="Contoh: Klik link di bio sekarang"
                class="w-full rounded-2xl border border-slate-300 p-2"
            />
        </label>

        <div class="mt-4 flex flex-wrap gap-2">
            <button
                id="generateBtn"
                class="rounded-xl bg-teal-600 px-4 py-2 text-sm font-semibold text-white hover:bg-teal-700"
                >Generate</button
            >
            <button
                id="copyBtn"
                class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100"
                >Copy Output</button
            >
        </div>

        <textarea
            id="output"
            class="mt-3 h-80 w-full rounded-2xl border border-slate-300 p-3 text-sm"
            readonly></textarea>
        <p id="message" class="mt-2 text-sm text-slate-600"></p>
    </section>

    <script>
        const topicEl = document.getElementById(
            "topic",
        ) as HTMLInputElement | null;
        const platformEl = document.getElementById(
            "platform",
        ) as HTMLSelectElement | null;
        const toneEl = document.getElementById(
            "tone",
        ) as HTMLSelectElement | null;
        const audienceEl = document.getElementById(
            "audience",
        ) as HTMLInputElement | null;
        const countEl = document.getElementById(
            "count",
        ) as HTMLInputElement | null;
        const withEmojiEl = document.getElementById(
            "withEmoji",
        ) as HTMLInputElement | null;
        const ctaEl = document.getElementById("cta") as HTMLInputElement | null;
        const outputEl = document.getElementById(
            "output",
        ) as HTMLTextAreaElement | null;
        const messageEl = document.getElementById(
            "message",
        ) as HTMLParagraphElement | null;

        const intros: Record<string, string[]> = {
            friendly: [
                "Hai teman-teman",
                "Yuk cek ini",
                "Buat kamu yang butuh inspirasi",
            ],
            promo: [
                "Promo spesial",
                "Diskon terbatas",
                "Jangan sampai kelewatan",
            ],
            professional: [
                "Update penting",
                "Insight terbaru",
                "Strategi efektif",
            ],
            casual: [
                "Lagi cari yang simpel?",
                "Cocok buat kamu",
                "Ini worth to try",
            ],
        };

        const emojis = ["✨", "🔥", "🚀", "✅", "🌟", "🎯"];

        const makeHashtags = (topic: string, platform: string) => {
            const words = topic
                .toLowerCase()
                .replace(/[^a-z0-9\s]/g, " ")
                .split(/\s+/)
                .filter((w) => w.length > 2)
                .slice(0, 5)
                .map((w) => `#${w}`);
            const platformTag =
                platform === "Instagram"
                    ? ["#instagram", "#instadaily"]
                    : platform === "TikTok"
                      ? ["#fyp", "#tiktokindonesia"]
                      : platform === "X"
                        ? ["#thread", "#update"]
                        : ["#linkedin", "#professional"];

            return [...new Set([...platformTag, ...words, "#viral", "#konten"])]
                .slice(0, 8)
                .join(" ");
        };

        document
            .getElementById("generateBtn")
            ?.addEventListener("click", () => {
                const topic = (topicEl?.value ?? "").trim();
                if (!topic) {
                    if (messageEl) messageEl.textContent = "Topik wajib diisi.";
                    return;
                }

                const platform = platformEl?.value ?? "Instagram";
                const tone = toneEl?.value ?? "friendly";
                const audience = (audienceEl?.value ?? "audiens umum").trim();
                const count = Math.min(
                    20,
                    Math.max(1, Number(countEl?.value ?? 6)),
                );
                const withEmoji = withEmojiEl?.checked ?? true;
                const customCta = (ctaEl?.value ?? "").trim();

                const lines = Array.from({ length: count }, (_, i) => {
                    const introSet = intros[tone] ?? intros.friendly;
                    const intro = introSet[i % introSet.length];
                    const emojiLeft = withEmoji
                        ? `${emojis[i % emojis.length]} `
                        : "";
                    const emojiRight = withEmoji
                        ? ` ${emojis[(i + 2) % emojis.length]}`
                        : "";
                    const cta = customCta || "Klik untuk info lengkap.";
                    const hashtags = makeHashtags(topic, platform);
                    return `${i + 1}. ${emojiLeft}${intro}${emojiRight}\n${topic} untuk ${audience}. ${cta}\n${hashtags}`;
                });

                if (outputEl) outputEl.value = lines.join("\n\n");
                if (messageEl)
                    messageEl.textContent = `${count} caption + hashtag berhasil dibuat.`;
            });

        document
            .getElementById("copyBtn")
            ?.addEventListener("click", async () => {
                const text = outputEl?.value ?? "";
                if (!text) return;
                await navigator.clipboard.writeText(text);
                if (messageEl) messageEl.textContent = "Output tersalin.";
            });
    </script>
</BaseLayout>
