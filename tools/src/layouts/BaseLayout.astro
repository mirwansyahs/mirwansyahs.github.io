    : `${currentToolName} adalah tool praktis untuk membantu workflow developer secara cepat langsung dari browser.`;
const toolHowToUse =
    HOW_TO_USE_BY_CATEGORY[currentToolCategory] ??
    HOW_TO_USE_BY_CATEGORY.Lainnya;
const toolExample =
    TOOL_EXAMPLES[toolSlug] ??
    `Buka ${currentToolName}, masukkan input yang relevan, proses data, lalu gunakan hasilnya di project Anda.`;
const toolWhyDevelopersUse =
    WHY_DEVELOPERS_USE_BY_CATEGORY[currentToolCategory] ??
    WHY_DEVELOPERS_USE_BY_CATEGORY.Lainnya;
const toolFaq = FAQ_BY_CATEGORY[currentToolCategory] ?? FAQ_BY_CATEGORY.Lainnya;
