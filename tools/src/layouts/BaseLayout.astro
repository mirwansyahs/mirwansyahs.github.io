<!doctype html>
<html lang="id">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link
            rel="preconnect"
            href="https://fonts.gstatic.com"
            crossorigin="anonymous"
        />
        <link
            rel="stylesheet"
            href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Sora:wght@600;700;800&display=swap"
        />
        <meta name="description" content={description} />
        <meta name="robots" content="index, follow, max-image-preview:large" />
        <meta property="og:type" content="website" />
        <meta property="og:site_name" content={SITE.name} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:url" content={canonical} />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:creator" content={SITE.twitter} />
        <link rel="canonical" href={canonical} />
        <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
        <script
            type="application/ld+json"
            set:html={JSON.stringify(pageJsonLd)}
        />
        {
            toolJsonLd && (
                <script
                    type="application/ld+json"
                    set:html={JSON.stringify(toolJsonLd)}
                />
            )
        }
        {
            adsenseClient && (
                <script
                    async
                    src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClient}`}
                    crossorigin="anonymous"
                />
            )
        }
        <title>{title}</title>
    </head>
    <body class="bg-slate-50 text-slate-900 antialiased">
        <div class="relative min-h-screen overflow-x-hidden">
            <div
                class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(circle_at_top_right,_#ffd8a8,_transparent_42%),radial-gradient(circle_at_bottom_left,_#99f6e4,_transparent_38%)]"
            >
            </div>

            <header
                class="relative z-40 border-b border-slate-200/80 bg-white/80 backdrop-blur"
            >
                <div class="mx-auto max-w-6xl px-4 py-4 md:px-8">
                    <div class="flex items-center justify-between gap-3">
                        <a
                            href="/"
                            class="text-xl font-black tracking-tight text-slate-900"
                            >General Tools</a
                        >

                        <button
                            id="mobileNavToggle"
                            type="button"
                            class="inline-flex items-center justify-center rounded-xl border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-50 md:hidden"
                            aria-controls="mobileNavMenu"
                            aria-expanded="false"
                        >
                            Menu
                        </button>

                        <nav
                            aria-label="Main Navigation Desktop"
                            class="hidden max-w-[70%] items-center gap-2 overflow-visible text-sm md:flex"
                        >
                            {
                                primaryNavItems.map((item) => (
                                    <a
                                        href={item.href}
                                        class={`whitespace-nowrap rounded-full border px-4 py-2 font-semibold transition ${
                                            isActiveNav(item.href)
                                                ? "border-teal-600 bg-teal-600 text-white"
                                                : "border-transparent text-slate-700 hover:border-slate-300 hover:bg-white hover:text-slate-900"
                                        }`}
                                    >
                                        {item.label}
                                    </a>
                                ))
                            }
                            {
                                hasOverflowNav && (
                                    <details class="group relative z-50">
                                        <summary
                                            class={`list-none cursor-pointer whitespace-nowrap rounded-full border px-4 py-2 font-semibold transition ${
                                                isOverflowActive
                                                    ? "border-teal-600 bg-teal-600 text-white"
                                                    : "border-transparent text-slate-700 hover:border-slate-300 hover:bg-white hover:text-slate-900"
                                            }`}
                                        >
                                            More
                                        </summary>
                                        <div class="absolute right-0 z-50 mt-2 min-w-[220px] rounded-2xl border border-slate-200 bg-white p-2 shadow-xl">
                                            <div class="flex flex-col gap-1">
                                                {overflowNavItems.map(
                                                    (item) => (
                                                        <a
                                                            href={item.href}
                                                            class={`rounded-xl border px-3 py-2 text-sm font-semibold transition ${
                                                                isActiveNav(
                                                                    item.href,
                                                                )
                                                                    ? "border-teal-600 bg-teal-600 text-white"
                                                                    : "border-transparent text-slate-700 hover:border-slate-200 hover:bg-slate-50"
                                                            }`}
                                                        >
                                                            {item.label}
                                                        </a>
                                                    ),
                                                )}
                                            </div>
                                        </div>
                                    </details>
                                )
                            }
                        </nav>
                    </div>

                    <form
                        id="globalToolSearchForm"
                        action="/"
                        method="get"
                        class="mt-3 flex flex-col gap-2 md:flex-row"
                        data-nav-items={JSON.stringify(NAV_ITEMS)}
                    >
                        <label class="sr-only" for="globalToolSearchInput"
                            >Cari tools</label
                        >
                        <input
                            id="globalToolSearchInput"
                            name="q"
                            type="search"
                            list="globalToolSearchOptions"
                            autocomplete="off"
                            placeholder="Cari tools... contoh: jwt, regex, timestamp"
                            class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-2 text-sm text-slate-900 outline-none ring-teal-500 transition focus:ring"
                        />
                        <datalist id="globalToolSearchOptions">
                            {
                                NAV_ITEMS.map((item) => (
                                    <option value={item.label} />
                                ))
                            }
                        </datalist>
                        <button
                            type="submit"
                            class="rounded-xl bg-teal-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-teal-700 md:self-start"
                        >
                            Search
                        </button>
                    </form>

                    <nav
                        id="mobileNavMenu"
                        aria-label="Main Navigation Mobile"
                        class="mt-3 hidden flex-col gap-2 rounded-2xl border border-slate-200 bg-white p-3 md:hidden"
                    >
                        {
                            NAV_ITEMS.map((item) => (
                                <a
                                    href={item.href}
                                    class={`rounded-xl border px-3 py-2 text-sm font-semibold transition ${
                                        isActiveNav(item.href)
                                            ? "border-teal-600 bg-teal-600 text-white"
                                            : "border-slate-200 text-slate-700 hover:bg-slate-50"
                                    }`}
                                >
                                    {item.label}
                                </a>
                            ))
                        }
                    </nav>
                </div>
            </header>

            <main
                class={`mx-auto grid w-full max-w-6xl gap-4 px-4 py-4 md:px-8 md:py-4 ${isToolsPage ? "lg:grid-cols-1" : "md:grid-cols-[minmax(0,1fr)_300px] md:py-10"}`}
            >
                <section class="min-h-0">
                    <slot />
                    {
                        isToolsPage && (
                            <section class="mt-4 rounded-3xl border border-slate-200 bg-white p-4 shadow-sm md:p-5">
                                <h2 class="text-xl font-black text-slate-900 md:text-2xl">
                                    Tool Guide
                                </h2>
                                <p class="mt-1 text-sm text-slate-600">
                                    Ringkasan cepat untuk memahami dan memakai
                                    tool ini.
                                </p>

                                <div class="mt-4 space-y-4 text-sm text-slate-700">
                                    <section class="rounded-2xl border border-slate-200 bg-slate-50 p-3">
                                        <h3 class="text-base font-bold text-slate-900">
                                            What is
                                        </h3>
                                        <p class="mt-1">{toolWhatIs}</p>
                                    </section>

                                    <section class="rounded-2xl border border-slate-200 bg-slate-50 p-3">
                                        <h3 class="text-base font-bold text-slate-900">
                                            How to use
                                        </h3>
                                        <ol class="mt-2 list-decimal space-y-1 pl-5">
                                            {toolHowToUse.map((step) => (
                                                <li>{step}</li>
                                            ))}
                                        </ol>
                                    </section>

                                    <section class="rounded-2xl border border-slate-200 bg-slate-50 p-3">
                                        <h3 class="text-base font-bold text-slate-900">
                                            Example
                                        </h3>
                                        <p class="mt-1">{toolExample}</p>
                                    </section>

                                    <section class="rounded-2xl border border-slate-200 bg-slate-50 p-3">
                                        <h3 class="text-base font-bold text-slate-900">
                                            Why developers use
                                        </h3>
                                        <ul class="mt-2 list-disc space-y-1 pl-5">
                                            {toolWhyDevelopersUse.map(
                                                (point) => (
                                                    <li>{point}</li>
                                                ),
                                            )}
                                        </ul>
                                    </section>

                                    <section class="rounded-2xl border border-slate-200 bg-slate-50 p-3">
                                        <h3 class="text-base font-bold text-slate-900">
                                            FAQ
                                        </h3>
                                        <div class="mt-2 space-y-2">
                                            {toolFaq.map((item) => (
                                                <details class="rounded-xl border border-slate-200 bg-white p-3">
                                                    <summary class="cursor-pointer font-semibold text-slate-800">
                                                        {item.q}
                                                    </summary>
                                                    <p class="mt-2 text-slate-700">
                                                        {item.a}
                                                    </p>
                                                </details>
                                            ))}
                                        </div>
                                    </section>
                                </div>
                            </section>
                        )
                    }
                </section>
                {
                    !isToolsPage && (
                        <aside class="space-y-4">
                            <div class="sticky top-6 rounded-2xl border border-slate-200 bg-white p-4 text-sm text-slate-600">
                                Utility tools ini dioptimalkan untuk pengalaman
                                cepat dan bersih. Pengaturan Auto Ads dikelola
                                dari dashboard AdSense.
                            </div>
                        </aside>
                    )
                }
            </main>

            <footer class="border-t border-slate-200/80 bg-white/80">
                <div class="mx-auto max-w-6xl px-4 py-8 md:px-8">
                    <p class="text-sm text-slate-600">
                        Build for speed, SEO, and practical daily workflows.
                        Update layout once, reflected across all pages.
                    </p>

                    <section class="mt-5 space-y-5">
                        <h2
                            class="text-sm font-bold uppercase tracking-[0.08em] text-slate-700"
                        >
                            Semua Tools per Kategori
                        </h2>
                        {
                            footerToolGroups.map((group) => (
                                <div>
                                    <h3 class="text-xs font-bold uppercase tracking-[0.08em] text-teal-700">
                                        {group.category}
                                    </h3>
                                    <div class="mt-2 grid gap-2 sm:grid-cols-2 lg:grid-cols-3">
                                        {group.items.map((item) => (
                                            <a
                                                href={item.href}
                                                class={`rounded-2xl border px-4 py-3 text-sm font-semibold transition ${
                                                    isActiveNav(item.href)
                                                        ? "border-teal-600 bg-teal-600 text-white"
                                                        : "border-slate-200 bg-white text-slate-700 hover:border-slate-300 hover:bg-slate-50"
                                                }`}
                                            >
                                                {item.label}
                                            </a>
                                        ))}
                                    </div>
                                </div>
                            ))
                        }
                    </section>
                </div>
            </footer>
        </div>

        <script>
            const toggleBtn = document.getElementById("mobileNavToggle");
            const menu = document.getElementById("mobileNavMenu");
            const globalSearchForm = document.getElementById(
                "globalToolSearchForm",
            ) as HTMLFormElement | null;
            const globalSearchInput = document.getElementById(
                "globalToolSearchInput",
            ) as HTMLInputElement | null;

            if (globalSearchInput) {
                const params = new URLSearchParams(window.location.search);
                const existingQuery = params.get("q");
                if (existingQuery) {
                    globalSearchInput.value = existingQuery;
                }
            }

            globalSearchForm?.addEventListener("submit", (event) => {
                const query = globalSearchInput?.value.trim() ?? "";
                if (!query) {
                    event.preventDefault();
                    return;
                }

                const rawNavItems =
                    globalSearchForm.dataset.navItems?.trim() ?? "[]";
                let navItems: Array<{ label: string; href: string }> = [];
                try {
                    navItems = JSON.parse(rawNavItems);
                } catch {
                    navItems = [];
                }

                const normalized = query.toLowerCase();
                const exact = navItems.find(
                    (item) => item.label.toLowerCase() === normalized,
                );

                if (exact) {
                    event.preventDefault();
                    window.location.href = exact.href;
                }
            });

            toggleBtn?.addEventListener("click", () => {
                const isOpen =
                    toggleBtn.getAttribute("aria-expanded") === "true";
                toggleBtn.setAttribute("aria-expanded", String(!isOpen));
                menu?.classList.toggle("hidden", isOpen);
                menu?.classList.toggle("flex", !isOpen);
            });
        </script>
    </body>
</html>
