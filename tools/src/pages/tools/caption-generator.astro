---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
    title="Caption Generator - Irwansyah Tools"
    description="Generate caption media sosial otomatis untuk Instagram, TikTok, X, dan LinkedIn lengkap dengan hashtag dan CTA."
    canonicalPath="/tools/caption-generator"
>
    <section
        class="rounded-3xl border border-slate-200 bg-white p-4 shadow-sm md:p-5"
    >
        <h1 class="text-2xl font-black text-slate-900 md:text-3xl">
            Caption Generator
        </h1>
        <p class="mt-1 text-sm text-slate-600">
            Buat caption cepat berdasarkan topik, platform, tone, dan target
            audiens.
        </p>

        <div class="mt-4 grid gap-3 md:grid-cols-2">
            <label class="block text-sm">
                <span class="mb-1 block font-semibold text-slate-700"
                    >Platform</span
                >
                <select
                    id="captionPlatform"
                    class="w-full rounded-2xl border border-slate-300 p-2"
                >
                    <option value="Instagram">Instagram</option>
                    <option value="TikTok">TikTok</option>
                    <option value="X">X (Twitter)</option>
                    <option value="LinkedIn">LinkedIn</option>
                </select>
            </label>
            <label class="block text-sm">
                <span class="mb-1 block font-semibold text-slate-700">Tone</span
                >
                <select
                    id="captionTone"
                    class="w-full rounded-2xl border border-slate-300 p-2"
                >
                    <option value="friendly">Friendly</option>
                    <option value="professional">Professional</option>
                    <option value="fun">Fun</option>
                    <option value="urgent">Urgent</option>
                </select>
            </label>
        </div>

        <div class="mt-3 grid gap-3 md:grid-cols-2">
            <label class="block text-sm md:col-span-2">
                <span class="mb-1 block font-semibold text-slate-700"
                    >Topik</span
                >
                <input
                    id="captionTopic"
                    type="text"
                    placeholder="Contoh: promo bukber, launching produk skincare, webinar coding"
                    class="w-full rounded-2xl border border-slate-300 p-2"
                />
            </label>
            <label class="block text-sm">
                <span class="mb-1 block font-semibold text-slate-700"
                    >Target Audiens</span
                >
                <input
                    id="captionAudience"
                    type="text"
                    placeholder="Contoh: mahasiswa, ibu rumah tangga, UMKM"
                    class="w-full rounded-2xl border border-slate-300 p-2"
                />
            </label>
            <label class="block text-sm">
                <span class="mb-1 block font-semibold text-slate-700"
                    >Jumlah Caption</span
                >
                <input
                    id="captionCount"
                    type="number"
                    min="1"
                    max="20"
                    value="5"
                    class="w-full rounded-2xl border border-slate-300 p-2"
                />
            </label>
        </div>

        <label class="mt-3 block text-sm">
            <span class="mb-1 block font-semibold text-slate-700"
                >Call to Action (Opsional)</span
            >
            <input
                id="captionCta"
                type="text"
                placeholder="Contoh: Klik link di bio sekarang"
                class="w-full rounded-2xl border border-slate-300 p-2"
            />
        </label>

        <div class="mt-4 flex flex-wrap gap-2">
            <button
                id="captionGenerateBtn"
                class="rounded-xl bg-teal-600 px-4 py-2 text-sm font-semibold text-white hover:bg-teal-700"
            >
                Generate Caption
            </button>
            <button
                id="captionCopyBtn"
                class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100"
            >
                Copy Output
            </button>
        </div>

        <textarea
            id="captionOutput"
            class="mt-3 h-72 w-full rounded-2xl border border-slate-300 p-3 text-sm"
            readonly></textarea>
        <p id="captionMessage" class="mt-2 text-sm text-slate-600"></p>
    </section>

    <script>
        const platformEl = document.getElementById(
            "captionPlatform",
        ) as HTMLSelectElement | null;
        const toneEl = document.getElementById(
            "captionTone",
        ) as HTMLSelectElement | null;
        const topicEl = document.getElementById(
            "captionTopic",
        ) as HTMLInputElement | null;
        const audienceEl = document.getElementById(
            "captionAudience",
        ) as HTMLInputElement | null;
        const countEl = document.getElementById(
            "captionCount",
        ) as HTMLInputElement | null;
        const ctaEl = document.getElementById(
            "captionCta",
        ) as HTMLInputElement | null;
        const outputEl = document.getElementById(
            "captionOutput",
        ) as HTMLTextAreaElement | null;
        const messageEl = document.getElementById(
            "captionMessage",
        ) as HTMLParagraphElement | null;

        const openings: Record<string, string[]> = {
            friendly: [
                "Teman-teman,",
                "Hai semuanya,",
                "Yuk cek ini,",
                "Buat kamu yang lagi cari solusi,",
            ],
            professional: [
                "Update terbaru untuk Anda,",
                "Informasi penting,",
                "Kami menghadirkan,",
                "Untuk kebutuhan profesional,",
            ],
            fun: [
                "Siap bikin harimu lebih seru?",
                "Waktunya upgrade vibes!",
                "Stop scroll dulu,",
                "Ini dia yang kamu tunggu,",
            ],
            urgent: [
                "Jangan sampai ketinggalan,",
                "Slot terbatas,",
                "Hari ini terakhir,",
                "Kesempatan terbatas,",
            ],
        };

        const benefits = [
            "praktis dipakai",
            "hemat waktu",
            "mudah dipahami",
            "siap dipakai kapan saja",
            "cocok untuk pemula dan profesional",
            "hasil lebih rapi dan cepat",
        ];

        const platformHints: Record<string, string> = {
            Instagram: "Simpan postingan ini biar tidak lupa.",
            TikTok: "Comment keyword-nya kalau mau versi lengkap.",
            X: "Retweet kalau ini bermanfaat.",
            LinkedIn: "Bagikan ke rekan kerja yang butuh insight ini.",
        };

        const pick = <T,>(items: readonly T[], seed: number) =>
            items[seed % items.length];

        const toHashtags = (topic: string, platform: string) => {
            const words = topic
                .toLowerCase()
                .replace(/[^a-z0-9\s]/g, " ")
                .split(/\s+/)
                .filter((word) => word.length > 2)
                .slice(0, 4)
                .map((word) => `#${word}`);
            const platformTag =
                platform === "X" ? "#thread" : "#contentcreator";
            return [...new Set([platformTag, ...words, "#produktif", "#viral"])]
                .slice(0, 6)
                .join(" ");
        };

        document
            .getElementById("captionGenerateBtn")
            ?.addEventListener("click", () => {
                const topic = (topicEl?.value ?? "").trim();
                if (!topic) {
                    if (messageEl) messageEl.textContent = "Topik wajib diisi.";
                    return;
                }

                const platform = platformEl?.value ?? "Instagram";
                const tone = (toneEl?.value ??
                    "friendly") as keyof typeof openings;
                const audience = (audienceEl?.value ?? "audiens umum").trim();
                const count = Math.min(
                    20,
                    Math.max(1, Number(countEl?.value ?? 5)),
                );
                const customCta = (ctaEl?.value ?? "").trim();

                const lines = Array.from({ length: count }, (_, i) => {
                    const intro = pick(openings[tone], i + topic.length);
                    const benefit = pick(benefits, i * 3 + audience.length);
                    const cta =
                        customCta ||
                        platformHints[platform] ||
                        "Klik untuk info lengkap.";
                    const hashtags = toHashtags(topic, platform);
                    return `${i + 1}. ${intro} ${topic} untuk ${audience} dengan manfaat ${benefit}. ${cta}\n${hashtags}`;
                });

                if (outputEl) outputEl.value = lines.join("\n\n");
                if (messageEl)
                    messageEl.textContent = `${count} caption berhasil dibuat untuk ${platform}.`;
            });

        document
            .getElementById("captionCopyBtn")
            ?.addEventListener("click", async () => {
                const text = outputEl?.value ?? "";
                if (!text) return;
                await navigator.clipboard.writeText(text);
                if (messageEl)
                    messageEl.textContent = "Caption tersalin ke clipboard.";
            });
    </script>
</BaseLayout>
