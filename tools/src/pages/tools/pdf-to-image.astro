---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
    title="PDF to Image - Irwansyah Tools"
    description="Konversi halaman PDF menjadi gambar PNG/JPEG langsung di browser tanpa upload ke server."
    canonicalPath="/tools/pdf-to-image"
>
    <section
        class="rounded-3xl border border-slate-200 bg-white p-4 shadow-sm md:p-5"
    >
        <h1 class="text-2xl font-black text-slate-900 md:text-3xl">
            PDF to Image
        </h1>
        <p class="mt-1 text-sm text-slate-600">
            Render halaman PDF menjadi gambar. Cocok untuk share preview halaman
            tertentu.
        </p>

        <input
            id="pdfImageInput"
            type="file"
            accept="application/pdf"
            class="mt-3 block w-full text-sm"
        />

        <div class="mt-3 grid gap-3 md:grid-cols-3">
            <label class="block text-sm">
                <span class="mb-1 block font-semibold text-slate-700"
                    >Scale (DPI)</span
                >
                <input
                    id="pdfImageScale"
                    type="number"
                    min="1"
                    step="0.2"
                    value="2"
                    class="w-full rounded-2xl border border-slate-300 p-2"
                />
            </label>
            <label class="block text-sm">
                <span class="mb-1 block font-semibold text-slate-700"
                    >Format Output</span
                >
                <select
                    id="pdfImageFormat"
                    class="w-full rounded-2xl border border-slate-300 p-2"
                >
                    <option value="image/png">PNG</option>
                    <option value="image/jpeg">JPEG</option>
                </select>
            </label>
            <label class="block text-sm">
                <span class="mb-1 block font-semibold text-slate-700"
                    >Quality (JPEG)</span
                >
                <input
                    id="pdfImageQuality"
                    type="range"
                    min="0.5"
                    max="1"
                    step="0.05"
                    value="0.9"
                    class="w-full"
                />
            </label>
        </div>

        <button
            id="pdfImageRunBtn"
            class="mt-3 rounded-xl bg-teal-600 px-4 py-2 text-sm font-semibold text-white hover:bg-teal-700"
            >Convert PDF to Image</button
        >
        <p id="pdfImageMessage" class="mt-3 text-sm text-slate-600"></p>
        <div id="pdfImageOutput" class="mt-3 grid gap-4"></div>
    </section>

    <script
        src="https://cdn.jsdelivr.net/npm/pdfjs-dist@3.11.174/build/pdf.min.js"
    ></script>
    <script>
        const inputEl = document.getElementById(
            "pdfImageInput",
        ) as HTMLInputElement | null;
        const scaleEl = document.getElementById(
            "pdfImageScale",
        ) as HTMLInputElement | null;
        const formatEl = document.getElementById(
            "pdfImageFormat",
        ) as HTMLSelectElement | null;
        const qualityEl = document.getElementById(
            "pdfImageQuality",
        ) as HTMLInputElement | null;
        const messageEl = document.getElementById(
            "pdfImageMessage",
        ) as HTMLParagraphElement | null;
        const outputEl = document.getElementById(
            "pdfImageOutput",
        ) as HTMLDivElement | null;

        (window as any).pdfjsLib.GlobalWorkerOptions.workerSrc =
            "https://cdn.jsdelivr.net/npm/pdfjs-dist@3.11.174/build/pdf.worker.min.js";

        document
            .getElementById("pdfImageRunBtn")
            ?.addEventListener("click", async () => {
                try {
                    const file = inputEl?.files?.[0];
                    if (!file) {
                        if (messageEl)
                            messageEl.textContent =
                                "Silakan pilih file PDF terlebih dahulu.";
                        return;
                    }

                    if (outputEl) outputEl.innerHTML = "";
                    if (messageEl)
                        messageEl.textContent = "Memproses PDF ke image...";

                    const data = new Uint8Array(await file.arrayBuffer());
                    const pdfDoc = await (window as any).pdfjsLib.getDocument({
                        data,
                    }).promise;
                    const scale = Math.max(1, Number(scaleEl?.value ?? 2));
                    const format = formatEl?.value ?? "image/png";
                    const quality = Number(qualityEl?.value ?? 0.9);

                    for (
                        let pageNum = 1;
                        pageNum <= pdfDoc.numPages;
                        pageNum += 1
                    ) {
                        const page = await pdfDoc.getPage(pageNum);
                        const viewport = page.getViewport({ scale });
                        const canvas = document.createElement("canvas");
                        canvas.width = viewport.width;
                        canvas.height = viewport.height;
                        const context = canvas.getContext("2d");
                        if (!context)
                            throw new Error("Canvas context tidak tersedia.");

                        await page.render({ canvasContext: context, viewport })
                            .promise;
                        const dataUrl = canvas.toDataURL(format, quality);

                        const wrapper = document.createElement("div");
                        wrapper.className =
                            "rounded-2xl border border-slate-200 bg-white p-3";

                        const title = document.createElement("p");
                        title.className =
                            "mb-2 text-sm font-semibold text-slate-700";
                        title.textContent = `Page ${pageNum}`;

                        const img = document.createElement("img");
                        img.src = dataUrl;
                        img.className = "rounded-xl border border-slate-200";

                        const download = document.createElement("a");
                        download.href = dataUrl;
                        download.download = `pdf-page-${pageNum}.${format === "image/png" ? "png" : "jpg"}`;
                        download.className =
                            "mt-2 inline-flex rounded-xl border border-slate-300 px-3 py-1.5 text-xs font-semibold text-slate-700 hover:bg-slate-100";
                        download.textContent = "Download page";

                        wrapper.appendChild(title);
                        wrapper.appendChild(img);
                        wrapper.appendChild(download);
                        outputEl?.appendChild(wrapper);
                    }

                    if (messageEl)
                        messageEl.textContent = `Konversi selesai. Total halaman: ${pdfDoc.numPages}.`;
                } catch (error) {
                    if (messageEl)
                        messageEl.textContent = `Gagal convert PDF ke image: ${error instanceof Error ? error.message : "Unknown error"}`;
                }
            });
    </script>
</BaseLayout>
