            color: #0f172a;
            padding: 8px 10px;
            text-align: center;
            font-size: 12px;
            font-weight: 600;
            line-height: 1.3;
            border-radius: 8px;
        }

        .flow-start,
        .flow-end {
            max-width: 180px;
            border-radius: 999px;
        }

        .flow-io {
            transform: skewX(-12deg);
        }

        .flow-io::before {
            content: "";
            display: block;
            transform: skewX(12deg);
        }

        .flow-decision {
            max-width: 200px;
            padding: 0;
            height: 74px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 0;
            clip-path: polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%);
        }

        .flow-decision span {
            display: inline-block;
            max-width: 120px;
        }

        .flow-arrow {
            color: #334155;
            font-size: 14px;
            line-height: 1;
        }

        .flow-branches {
            width: 100%;
            display: grid;
