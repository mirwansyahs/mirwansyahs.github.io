            display: flex;
            flex-wrap: wrap;
            gap: 14px;
            align-items: flex-start;
        }

        .flow-lane {
            display: flex;
            min-width: 220px;
            flex: 1 1 260px;
            flex-direction: column;
            align-items: center;
            gap: 6px;
        }

        .flow-node {
            width: 100%;
            border: 1px solid #94a3b8;
