---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="JSON Viewer Suite - Unstringify, Beautify, JSON to XML/CSV"
  description="JSON Viewer lengkap: unstringify JSON string, beautify JSON, convert JSON ke XML, dan JSON ke CSV."
  canonicalPath="/tools/json-viewer"
>
  <section class="rounded-3xl border border-slate-200 bg-white p-4 shadow-sm md:p-5 lg:h-full lg:overflow-hidden">
    <p class="text-xs font-bold uppercase tracking-[0.16em] text-teal-700">Priority Tool</p>
    <h1 class="mt-1 text-2xl font-black text-slate-900 md:text-3xl">JSON Viewer Suite</h1>
    <p class="mt-1 text-sm text-slate-600">
      Satu halaman untuk parse JSON, unstringify escaped JSON string, beautify JSON,
      serta convert JSON ke XML dan CSV.
    </p>

    <div class="mt-3 grid gap-3 md:grid-cols-[1.2fr_1fr]">
      <label class="block">
        <span class="mb-2 block text-sm font-semibold text-slate-700">JSON Input</span>
        <textarea
          id="jsonInput"
          class="h-44 w-full rounded-2xl border border-slate-300 p-3 font-mono text-sm md:h-52 lg:h-[24vh]"
          placeholder='Contoh: "{\"name\":\"Irwansyah\",\"age\":29}" atau {"name":"Irwansyah"}'
        ></textarea>
      </label>

      <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
        <p class="text-sm font-semibold text-slate-800">Mode</p>
        <div class="mt-3 grid gap-2">
          <button class="json-mode-btn rounded-xl bg-teal-600 px-3 py-2 text-sm font-semibold text-white hover:bg-teal-700" data-mode="beautify">JSON Beautify</button>
          <button class="json-mode-btn rounded-xl border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-800 hover:bg-slate-100" data-mode="unstringify">Unstringify JSON</button>
          <button class="json-mode-btn rounded-xl border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-800 hover:bg-slate-100" data-mode="xml">JSON to XML</button>
          <button class="json-mode-btn rounded-xl border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-800 hover:bg-slate-100" data-mode="csv">JSON to CSV</button>
        </div>

        <button id="processJsonBtn" class="mt-4 w-full rounded-xl bg-amber-500 px-4 py-2 text-sm font-semibold text-slate-900 hover:bg-amber-400">
          Process
        </button>
        <button id="copyJsonBtn" class="mt-2 w-full rounded-xl border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100">
          Copy Output
        </button>
        <p id="jsonMessage" class="mt-3 text-sm text-slate-600"></p>
      </div>
    </div>

    <label class="mt-3 block">
      <span class="mb-2 block text-sm font-semibold text-slate-700">Output</span>
      <textarea id="jsonOutput" class="h-44 w-full rounded-2xl border border-slate-300 p-3 font-mono text-sm md:h-52 lg:h-[24vh]" readonly></textarea>
    </label>
  </section>

  <script>
    const inputEl = document.getElementById("jsonInput");
    const outputEl = document.getElementById("jsonOutput");
    const msgEl = document.getElementById("jsonMessage");
    const modeButtons = Array.from(document.querySelectorAll(".json-mode-btn"));

    let activeMode = "beautify";

    const setModeStyle = () => {
      for (const btn of modeButtons) {
        const isActive = btn.dataset.mode === activeMode;
        btn.classList.toggle("bg-teal-600", isActive);
        btn.classList.toggle("text-white", isActive);
        btn.classList.toggle("border-slate-300", !isActive);
        btn.classList.toggle("bg-white", !isActive);
        btn.classList.toggle("text-slate-800", !isActive);
      }
    };

    for (const btn of modeButtons) {
      btn.addEventListener("click", () => {
        activeMode = btn.dataset.mode || "beautify";
        setModeStyle();
      });
    }

    const parseFlexibleJson = (raw) => {
      let value = JSON.parse(raw);
      // Unwrap stringified JSON up to 5 levels to support deeply escaped payloads.
      for (let i = 0; i < 5; i += 1) {
        if (typeof value !== "string") break;
        try {
          value = JSON.parse(value);
        } catch {
          break;
        }
      }
      return value;
    };

    const escapeXml = (value) =>
      String(value)
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&apos;");

    const toXmlNode = (key, value) => {
      if (Array.isArray(value)) {
        return value.map((item) => toXmlNode(key, item)).join("");
      }
      if (value !== null && typeof value === "object") {
        const children = Object.entries(value)
          .map(([childKey, childValue]) => toXmlNode(childKey, childValue))
          .join("");
        return `<${key}>${children}</${key}>`;
      }
      return `<${key}>${escapeXml(value)}</${key}>`;
    };

    const jsonToXml = (data) => {
      if (data !== null && typeof data === "object" && !Array.isArray(data)) {
        const body = Object.entries(data)
          .map(([key, value]) => toXmlNode(key, value))
          .join("");
        return `<?xml version="1.0" encoding="UTF-8"?>\n<root>${body}</root>`;
      }
      if (Array.isArray(data)) {
        const rows = data.map((item) => toXmlNode("item", item)).join("");
        return `<?xml version="1.0" encoding="UTF-8"?>\n<root>${rows}</root>`;
      }
      return `<?xml version="1.0" encoding="UTF-8"?>\n<root>${escapeXml(data)}</root>`;
    };

    const flattenRecord = (record, prefix = "") => {
      const out = {};
      for (const [key, value] of Object.entries(record)) {
        const col = prefix ? `${prefix}.${key}` : key;
        if (value !== null && typeof value === "object" && !Array.isArray(value)) {
          Object.assign(out, flattenRecord(value, col));
        } else if (Array.isArray(value)) {
          out[col] = JSON.stringify(value);
        } else {
          out[col] = value;
        }
      }
      return out;
    };

    const escapeCsv = (value) => {
      const stringValue = value == null ? "" : String(value);
      if (/[",\n]/.test(stringValue)) {
        return `"${stringValue.replace(/"/g, '""')}"`;
      }
      return stringValue;
    };

    const jsonToCsv = (data) => {
      const rows = Array.isArray(data) ? data : [data];
      const normalized = rows.map((row) =>
        row !== null && typeof row === "object" ? flattenRecord(row) : { value: row }
      );

      const headers = Array.from(
        normalized.reduce((set, row) => {
          Object.keys(row).forEach((key) => set.add(key));
          return set;
        }, new Set())
      );

      const csvRows = [headers.join(",")];
      for (const row of normalized) {
        csvRows.push(headers.map((h) => escapeCsv(row[h])).join(","));
      }
      return csvRows.join("\n");
    };

    document.getElementById("processJsonBtn")?.addEventListener("click", () => {
      try {
        const raw = inputEl?.value?.trim() || "";
        if (!raw) {
          msgEl.textContent = "Input JSON masih kosong.";
          outputEl.value = "";
          return;
        }

        const parsed = parseFlexibleJson(raw);
        if (activeMode === "beautify") {
          outputEl.value = JSON.stringify(parsed, null, 2);
          msgEl.textContent = "JSON berhasil di-beautify.";
          return;
        }

        if (activeMode === "unstringify") {
          outputEl.value = typeof parsed === "string" ? parsed : JSON.stringify(parsed, null, 2);
          msgEl.textContent = "JSON string berhasil di-unstringify.";
          return;
        }

        if (activeMode === "xml") {
          outputEl.value = jsonToXml(parsed);
          msgEl.textContent = "Konversi JSON ke XML berhasil.";
          return;
        }

        outputEl.value = jsonToCsv(parsed);
        msgEl.textContent = "Konversi JSON ke CSV berhasil.";
      } catch (error) {
        outputEl.value = "";
        msgEl.textContent = `Error: ${error instanceof Error ? error.message : "JSON tidak valid."}`;
      }
    });

    document.getElementById("copyJsonBtn")?.addEventListener("click", async () => {
      if (!outputEl.value) return;
      await navigator.clipboard.writeText(outputEl.value);
      msgEl.textContent = "Output tersalin ke clipboard.";
    });

    setModeStyle();
  </script>
</BaseLayout>
