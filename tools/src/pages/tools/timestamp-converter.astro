---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
    title="Timestamp Converter - Irwansyah Tools"
    description="Konversi Unix timestamp detik/milidetik ke tanggal normal dan sebaliknya secara cepat langsung di browser."
    canonicalPath="/tools/timestamp-converter"
>
    <section
        class="rounded-3xl border border-slate-200 bg-white p-4 shadow-sm md:p-5"
    >
        <h1 class="text-2xl font-black text-slate-900 md:text-3xl">
            Timestamp Converter
        </h1>
        <p class="mt-1 text-sm text-slate-600">
            Konversi Unix timestamp <code>seconds/milliseconds</code> ke format tanggal
            ISO lokal.
        </p>

        <div class="mt-3 grid gap-3 md:grid-cols-2">
            <label class="block">
                <span class="mb-2 block text-sm font-semibold text-slate-700"
                    >Unix Timestamp</span
                >
                <input
                    id="tsInput"
                    type="text"
                    class="w-full rounded-2xl border border-slate-300 p-3 font-mono text-sm"
                    placeholder="contoh: 1710000000 atau 1710000000000"
                />
            </label>
            <label class="block">
                <span class="mb-2 block text-sm font-semibold text-slate-700"
                    >Tanggal ISO</span
                >
                <input
                    id="isoInput"
                    type="datetime-local"
                    class="w-full rounded-2xl border border-slate-300 p-3 text-sm"
                />
            </label>
        </div>

        <div class="mt-3 flex flex-wrap gap-2">
            <button
                id="toDateBtn"
                class="rounded-xl bg-teal-600 px-4 py-2 text-sm font-semibold text-white hover:bg-teal-700"
                >Timestamp to Date</button
            >
            <button
                id="toTsBtn"
                class="rounded-xl bg-amber-500 px-4 py-2 text-sm font-semibold text-slate-900 hover:bg-amber-400"
                >Date to Timestamp</button
            >
            <button
                id="nowBtn"
                class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100"
                >Use Current Time</button
            >
        </div>

        <pre
            id="tsOutput"
            class="mt-3 overflow-x-auto rounded-2xl border border-slate-200 bg-slate-50 p-3 font-mono text-xs text-slate-700">
        </pre>
        <p id="tsMessage" class="mt-2 text-sm text-slate-600"></p>
    </section>

    <script>
        const tsInput = document.getElementById(
            "tsInput",
        ) as HTMLInputElement | null;
        const isoInput = document.getElementById(
            "isoInput",
        ) as HTMLInputElement | null;
        const outputEl = document.getElementById(
            "tsOutput",
        ) as HTMLPreElement | null;
        const messageEl = document.getElementById(
            "tsMessage",
        ) as HTMLParagraphElement | null;

        const formatLocalDateTime = (date: Date) => {
            const pad = (n: number) => String(n).padStart(2, "0");
            return `${date.getFullYear()}-${pad(date.getMonth() + 1)}-${pad(date.getDate())}T${pad(date.getHours())}:${pad(date.getMinutes())}`;
        };

        document.getElementById("toDateBtn")?.addEventListener("click", () => {
            const raw = (tsInput?.value ?? "").trim();
            const numeric = Number(raw);
            if (!Number.isFinite(numeric)) {
                if (messageEl)
                    messageEl.textContent = "Timestamp harus berupa angka.";
                return;
            }

            const ms = raw.length <= 10 ? numeric * 1000 : numeric;
            const date = new Date(ms);
            if (Number.isNaN(date.getTime())) {
                if (messageEl) messageEl.textContent = "Timestamp tidak valid.";
                return;
            }

            if (isoInput) isoInput.value = formatLocalDateTime(date);
            if (outputEl) {
                outputEl.textContent = [
                    `ISO UTC  : ${date.toISOString()}`,
                    `Local    : ${date.toString()}`,
                    `Seconds  : ${Math.floor(ms / 1000)}`,
                    `Millis   : ${ms}`,
                ].join("\n");
            }
            if (messageEl)
                messageEl.textContent = "Konversi timestamp berhasil.";
        });

        document.getElementById("toTsBtn")?.addEventListener("click", () => {
            const value = isoInput?.value ?? "";
            if (!value) {
                if (messageEl) messageEl.textContent = "Tanggal belum diisi.";
                return;
            }

            const date = new Date(value);
            if (Number.isNaN(date.getTime())) {
                if (messageEl)
                    messageEl.textContent = "Format tanggal tidak valid.";
                return;
            }

            const ms = date.getTime();
            if (tsInput) tsInput.value = String(Math.floor(ms / 1000));
            if (outputEl) {
                outputEl.textContent = [
                    `Input    : ${value}`,
                    `ISO UTC  : ${date.toISOString()}`,
                    `Seconds  : ${Math.floor(ms / 1000)}`,
                    `Millis   : ${ms}`,
                ].join("\n");
            }
            if (messageEl) messageEl.textContent = "Konversi tanggal berhasil.";
        });

        document.getElementById("nowBtn")?.addEventListener("click", () => {
            const now = new Date();
            if (isoInput) isoInput.value = formatLocalDateTime(now);
            if (tsInput)
                tsInput.value = String(Math.floor(now.getTime() / 1000));
            if (messageEl)
                messageEl.textContent = "Waktu sekarang sudah diisi.";
        });
    </script>
</BaseLayout>
