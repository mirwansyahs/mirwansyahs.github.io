---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
    title="QR Generator - Irwansyah Tools"
    description="Buat QR code dari URL atau teks, atur ukuran, margin, level error correction, lalu download PNG."
    canonicalPath="/tools/qr-generator"
>
    <section
        class="rounded-3xl border border-slate-200 bg-white p-4 shadow-sm md:p-5"
    >
        <h1 class="text-2xl font-black text-slate-900 md:text-3xl">
            QR Generator
        </h1>
        <p class="mt-1 text-sm text-slate-600">
            Generate QR code instan untuk link, kontak, promo, menu, atau teks
            bebas.
        </p>

        <label class="mt-4 block text-sm">
            <span class="mb-1 block font-semibold text-slate-700"
                >URL / Teks</span
            >
            <textarea
                id="qrTextInput"
                class="h-28 w-full rounded-2xl border border-slate-300 p-3 text-sm"
                placeholder="Masukkan URL atau teks..."></textarea>
        </label>

        <div class="mt-3 grid gap-3 md:grid-cols-3">
            <label class="block text-sm">
                <span class="mb-1 block font-semibold text-slate-700"
                    >Ukuran QR</span
                >
                <input
                    id="qrSize"
                    type="number"
                    min="120"
                    max="1024"
                    value="320"
                    class="w-full rounded-2xl border border-slate-300 p-2"
                />
            </label>
            <label class="block text-sm">
                <span class="mb-1 block font-semibold text-slate-700"
                    >Margin</span
                >
                <input
                    id="qrMargin"
                    type="number"
                    min="0"
                    max="10"
                    value="2"
                    class="w-full rounded-2xl border border-slate-300 p-2"
                />
            </label>
            <label class="block text-sm">
                <span class="mb-1 block font-semibold text-slate-700"
                    >Error Correction</span
                >
                <select
                    id="qrLevel"
                    class="w-full rounded-2xl border border-slate-300 p-2"
                >
                    <option value="L">L</option>
                    <option value="M" selected>M</option>
                    <option value="Q">Q</option>
                    <option value="H">H</option>
                </select>
            </label>
        </div>

        <div class="mt-4 flex flex-wrap gap-2">
            <button
                id="generateQrBtn"
                class="rounded-xl bg-teal-600 px-4 py-2 text-sm font-semibold text-white hover:bg-teal-700"
                >Generate QR</button
            >
            <button
                id="copyQrInputBtn"
                class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100"
                >Copy Input</button
            >
            <a
                id="downloadQrBtn"
                class="hidden rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100"
                download="qr-code.png">Download PNG</a
            >
        </div>

        <p id="qrMessage" class="mt-2 text-sm text-slate-600"></p>

        <div class="mt-3 rounded-2xl border border-slate-200 bg-slate-50 p-3">
            <div
                id="qrPreview"
                class="flex min-h-[340px] items-center justify-center rounded-xl border border-slate-200 bg-white p-3"
            >
            </div>
        </div>
    </section>

    <script src="https://cdn.jsdelivr.net/npm/qrcode/build/qrcode.min.js"
    ></script>
    <script>
        const inputEl = document.getElementById(
            "qrTextInput",
        ) as HTMLTextAreaElement | null;
        const sizeEl = document.getElementById(
            "qrSize",
        ) as HTMLInputElement | null;
        const marginEl = document.getElementById(
            "qrMargin",
        ) as HTMLInputElement | null;
        const levelEl = document.getElementById(
            "qrLevel",
        ) as HTMLSelectElement | null;
        const previewEl = document.getElementById(
            "qrPreview",
        ) as HTMLDivElement | null;
        const messageEl = document.getElementById(
            "qrMessage",
        ) as HTMLParagraphElement | null;
        const downloadEl = document.getElementById(
            "downloadQrBtn",
        ) as HTMLAnchorElement | null;

        const renderQr = async () => {
            const qrLib = (
                window as unknown as {
                    QRCode?: { toCanvas: (...args: unknown[]) => void };
                }
            ).QRCode;
            if (!qrLib || !previewEl) {
                if (messageEl) messageEl.textContent = "Library QR belum siap.";
                return;
            }

            const value = (inputEl?.value ?? "").trim();
            if (!value) {
                if (messageEl)
                    messageEl.textContent = "Isi URL atau teks dulu.";
                return;
            }

            const size = Math.min(
                1024,
                Math.max(120, Number(sizeEl?.value ?? 320)),
            );
            const margin = Math.min(
                10,
                Math.max(0, Number(marginEl?.value ?? 2)),
            );
            const level = (levelEl?.value ?? "M") as "L" | "M" | "Q" | "H";

            previewEl.innerHTML = "";
            const canvas = document.createElement("canvas");
            previewEl.appendChild(canvas);

            await new Promise<void>((resolve, reject) => {
                qrLib.toCanvas(
                    canvas,
                    value,
                    {
                        width: size,
                        margin,
                        errorCorrectionLevel: level,
                        color: { dark: "#0f172a", light: "#ffffff" },
                    },
                    (err?: Error) => {
                        if (err) reject(err);
                        else resolve();
                    },
                );
            });

            if (downloadEl) {
                downloadEl.href = canvas.toDataURL("image/png");
                downloadEl.classList.remove("hidden");
            }
            if (messageEl) messageEl.textContent = "QR code berhasil dibuat.";
        };

        document
            .getElementById("generateQrBtn")
            ?.addEventListener("click", async () => {
                try {
                    await renderQr();
                } catch {
                    if (messageEl)
                        messageEl.textContent = "Gagal membuat QR code.";
                }
            });

        document
            .getElementById("copyQrInputBtn")
            ?.addEventListener("click", async () => {
                const value = (inputEl?.value ?? "").trim();
                if (!value) return;
                await navigator.clipboard.writeText(value);
                if (messageEl)
                    messageEl.textContent = "Input tersalin ke clipboard.";
            });
    </script>
</BaseLayout>
