---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Base64 Encode and Decode - Irwansyah Tools"
  description="Tool gratis untuk Base64 encode dan decode text secara instan langsung dari browser."
  canonicalPath="/tools/base64-encode-decode"
>
  <section class="rounded-3xl border border-slate-200 bg-white p-4 shadow-sm md:p-5 lg:h-full lg:overflow-hidden">
    <h1 class="text-2xl font-black text-slate-900 md:text-3xl">Base64 Encode and Decode</h1>
    <p class="mt-1 text-sm text-slate-600">Masukkan text untuk encode atau string Base64 untuk decode.</p>

    <div class="mt-3 grid gap-3 md:grid-cols-2">
      <label class="block">
        <span class="mb-2 block text-sm font-semibold text-slate-700">Input</span>
        <textarea id="b64Input" class="h-44 w-full rounded-2xl border border-slate-300 p-3 font-mono text-sm md:h-52 lg:h-[34vh]" placeholder="Type here..."></textarea>
      </label>
      <label class="block">
        <span class="mb-2 block text-sm font-semibold text-slate-700">Output</span>
        <textarea id="b64Output" class="h-44 w-full rounded-2xl border border-slate-300 p-3 font-mono text-sm md:h-52 lg:h-[34vh]" readonly></textarea>
      </label>
    </div>

    <div class="mt-3 flex flex-wrap gap-2">
      <button id="encodeBtn" class="rounded-xl bg-teal-600 px-4 py-2 text-sm font-semibold text-white hover:bg-teal-700">Encode</button>
      <button id="decodeBtn" class="rounded-xl bg-amber-500 px-4 py-2 text-sm font-semibold text-slate-900 hover:bg-amber-400">Decode</button>
      <button id="copyB64Btn" class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100">Copy Output</button>
    </div>
    <p id="b64Message" class="mt-3 text-sm text-slate-600"></p>
  </section>

  <script>
    const inputEl = document.getElementById("b64Input");
    const outputEl = document.getElementById("b64Output");
    const messageEl = document.getElementById("b64Message");

    document.getElementById("encodeBtn")?.addEventListener("click", () => {
      const value = inputEl?.value ?? "";
      outputEl.value = btoa(unescape(encodeURIComponent(value)));
      messageEl.textContent = "Text berhasil di-encode ke Base64.";
    });

    document.getElementById("decodeBtn")?.addEventListener("click", () => {
      try {
        const value = inputEl?.value ?? "";
        outputEl.value = decodeURIComponent(escape(atob(value)));
        messageEl.textContent = "Base64 berhasil di-decode.";
      } catch {
        messageEl.textContent = "Format Base64 tidak valid.";
      }
    });

    document.getElementById("copyB64Btn")?.addEventListener("click", async () => {
      if (!outputEl.value) return;
      await navigator.clipboard.writeText(outputEl.value);
      messageEl.textContent = "Output tersalin ke clipboard.";
    });
  </script>
</BaseLayout>
