---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
    title="Twibbon Maker - Irwansyah Tools"
    description="Buat twibbon Ramadhan dan Idul Fitri dari template bawaan atau upload template sendiri, lalu download hasilnya."
    canonicalPath="/tools/twibbon-maker"
>
    <section
        class="rounded-3xl border border-slate-200 bg-white p-4 shadow-sm md:p-5"
    >
        <h1 class="text-2xl font-black text-slate-900 md:text-3xl">
            Twibbon Maker
        </h1>
        <p class="mt-1 text-sm text-slate-600">
            Pilih template twibbon Ramadhan/Idul Fitri bawaan, atau upload
            template sendiri.
        </p>

        <div class="mt-3 grid gap-3 md:grid-cols-2">
            <label class="block text-sm">
                <span class="mb-1 block font-semibold text-slate-700"
                    >Upload Foto</span
                >
                <input
                    id="twibbonPhotoInput"
                    type="file"
                    accept="image/*"
                    class="block w-full rounded-2xl border border-slate-300 bg-white p-2 text-sm text-slate-700 file:mr-3 file:rounded-xl file:border-0 file:bg-teal-600 file:px-4 file:py-2 file:font-semibold file:text-white hover:file:bg-teal-700"
                />
            </label>
            <label class="block text-sm">
                <span class="mb-1 block font-semibold text-slate-700"
                    >Upload Template Sendiri (PNG/SVG)</span
                >
                <input
                    id="twibbonTemplateUpload"
                    type="file"
                    accept="image/png,image/svg+xml,image/*"
                    class="block w-full rounded-2xl border border-slate-300 bg-white p-2 text-sm text-slate-700 file:mr-3 file:rounded-xl file:border-0 file:bg-teal-600 file:px-4 file:py-2 file:font-semibold file:text-white hover:file:bg-teal-700"
                />
            </label>
        </div>

        <label class="mt-3 block text-sm">
            <span class="mb-1 block font-semibold text-slate-700"
                >Template Bawaan</span
            >
            <select
                id="twibbonTemplateSelect"
                class="w-full rounded-2xl border border-slate-300 p-2"
            >
                <option value="/twibbon-templates/ramadhan-kareem.svg"
                    >Ramadhan Kareem</option
                >
                <option value="/twibbon-templates/ramadhan-lantern.svg"
                    >Ramadhan Lantern</option
                >
                <option value="/twibbon-templates/eid-mubarak.svg"
                    >Eid Mubarak</option
                >
                <option value="/twibbon-templates/ramadhan-moon-gold.svg"
                    >Ramadhan Moon Gold</option
                >
                <option value="/twibbon-templates/ramadhan-mosque-emerald.svg"
                    >Ramadhan Mosque Emerald</option
                >
                <option value="/twibbon-templates/ramadhan-classic-green.svg"
                    >Ramadhan Classic Green</option
                >
                <option value="/twibbon-templates/ramadhan-night-stars.svg"
                    >Ramadhan Night Stars</option
                >
                <option value="/twibbon-templates/eid-ketupat-green.svg"
                    >Eid Ketupat Green</option
                >
                <option value="/twibbon-templates/eid-gold-arch.svg"
                    >Eid Gold Arch</option
                >
                <option value="/twibbon-templates/eid-cream-lantern.svg"
                    >Eid Cream Lantern</option
                >
                <option value="/twibbon-templates/eid-festive-blue.svg"
                    >Eid Festive Blue</option
                >
                <option value="/twibbon-templates/eid-minimal-olive.svg"
                    >Eid Minimal Olive</option
                >
                <option value="/twibbon-templates/eid-modern-teal.svg"
                    >Eid Modern Teal</option
                >
            </select>
        </label>

        <div class="mt-3 grid gap-3 md:grid-cols-3">
            <label class="block text-sm md:col-span-2">
                <span class="mb-1 block font-semibold text-slate-700"
                    >Teks Ucapan Custom (Opsional)</span
                >
                <input
                    id="twibbonGreetingText"
                    type="text"
                    maxlength="90"
                    placeholder="Contoh: Selamat Idul Fitri 1447 H"
                    class="w-full rounded-2xl border border-slate-300 p-2"
                />
            </label>
            <label class="block text-sm">
                <span class="mb-1 block font-semibold text-slate-700"
                    >Warna Teks</span
                >
                <input
                    id="twibbonGreetingColor"
                    type="color"
                    value="#ffffff"
                    class="h-10 w-full rounded-xl border border-slate-300 p-1"
                />
            </label>
        </div>

        <div class="mt-3 grid gap-3 md:grid-cols-2">
            <label class="block text-sm">
                <span class="mb-1 block font-semibold text-slate-700"
                    >Ukuran Teks Ucapan</span
                >
                <input
                    id="twibbonGreetingSize"
                    type="range"
                    min="20"
                    max="76"
                    step="1"
                    value="42"
                    class="w-full"
                />
            </label>
            <label
                class="mt-6 inline-flex items-center gap-2 text-sm text-slate-700 md:mt-0"
            >
                <input
                    id="twibbonGreetingBackground"
                    type="checkbox"
                    class="h-4 w-4"
                    checked
                />
                Tampilkan background teks
            </label>
        </div>

        <div class="mt-3 grid gap-3 md:grid-cols-3">
            <label class="block text-sm">
                <span class="mb-1 block font-semibold text-slate-700"
                    >Zoom Foto</span
                >
                <input
                    id="twibbonZoom"
                    type="range"
                    min="1"
                    max="3"
                    step="0.05"
                    value="1.2"
                    class="w-full"
                />
            </label>
            <label class="block text-sm">
                <span class="mb-1 block font-semibold text-slate-700"
                    >Geser X</span
                >
                <input
                    id="twibbonOffsetX"
                    type="range"
                    min="-400"
                    max="400"
                    step="1"
                    value="0"
                    class="w-full"
                />
            </label>
            <label class="block text-sm">
                <span class="mb-1 block font-semibold text-slate-700"
                    >Geser Y</span
                >
                <input
                    id="twibbonOffsetY"
                    type="range"
                    min="-400"
                    max="400"
                    step="1"
                    value="0"
                    class="w-full"
                />
            </label>
        </div>

        <div class="mt-3 grid gap-3 md:grid-cols-2">
            <label class="block text-sm">
                <span class="mb-1 block font-semibold text-slate-700"
                    >Ukuran Output</span
                >
                <select
                    id="twibbonOutputSize"
                    class="w-full rounded-2xl border border-slate-300 p-2"
                >
                    <option value="1080">1080 x 1080</option>
                    <option value="2048">2048 x 2048</option>
                </select>
            </label>
            <label
                class="mt-6 inline-flex items-center gap-2 text-sm text-slate-700 md:mt-0"
            >
                <input
                    id="twibbonCircleCrop"
                    type="checkbox"
                    class="h-4 w-4"
                    checked
                />
                Gunakan crop lingkaran (disarankan untuk template bawaan)
            </label>
        </div>

        <div class="mt-3 flex flex-wrap gap-2">
            <button
                id="twibbonRenderBtn"
                class="rounded-xl bg-teal-600 px-4 py-2 text-sm font-semibold text-white hover:bg-teal-700"
                >Render Twibbon</button
            >
            <button
                id="twibbonResetBtn"
                class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100"
                >Reset Posisi</button
            >
            <a
                id="twibbonDownloadBtn"
                class="hidden rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100"
                download="twibbon-result.png">Download PNG</a
            >
        </div>

        <p id="twibbonMessage" class="mt-3 text-sm text-slate-600"></p>

        <div class="mt-3 rounded-2xl border border-slate-200 bg-slate-50 p-3">
            <canvas
                id="twibbonCanvas"
                width="1080"
                height="1080"
                class="mx-auto w-full max-w-[560px] rounded-xl border border-slate-200 bg-white"
            ></canvas>
        </div>
    </section>

    <script>
        const photoInputEl = document.getElementById(
            "twibbonPhotoInput",
        ) as HTMLInputElement | null;
        const templateSelectEl = document.getElementById(
            "twibbonTemplateSelect",
        ) as HTMLSelectElement | null;
        const templateUploadEl = document.getElementById(
            "twibbonTemplateUpload",
        ) as HTMLInputElement | null;
        const zoomEl = document.getElementById(
            "twibbonZoom",
        ) as HTMLInputElement | null;
        const offsetXEl = document.getElementById(
            "twibbonOffsetX",
        ) as HTMLInputElement | null;
        const offsetYEl = document.getElementById(
            "twibbonOffsetY",
        ) as HTMLInputElement | null;
        const outputSizeEl = document.getElementById(
            "twibbonOutputSize",
        ) as HTMLSelectElement | null;
        const circleCropEl = document.getElementById(
            "twibbonCircleCrop",
        ) as HTMLInputElement | null;
        const canvasEl = document.getElementById(
            "twibbonCanvas",
        ) as HTMLCanvasElement | null;
        const greetingTextEl = document.getElementById(
            "twibbonGreetingText",
        ) as HTMLInputElement | null;
        const greetingColorEl = document.getElementById(
            "twibbonGreetingColor",
        ) as HTMLInputElement | null;
        const greetingSizeEl = document.getElementById(
            "twibbonGreetingSize",
        ) as HTMLInputElement | null;
        const greetingBgEl = document.getElementById(
            "twibbonGreetingBackground",
        ) as HTMLInputElement | null;
        const messageEl = document.getElementById(
            "twibbonMessage",
        ) as HTMLParagraphElement | null;
        const downloadEl = document.getElementById(
            "twibbonDownloadBtn",
        ) as HTMLAnchorElement | null;

        let customTemplateUrl = "";

        const loadImage = (src: string) =>
            new Promise<HTMLImageElement>((resolve, reject) => {
                const img = new Image();
                img.onload = () => resolve(img);
                img.onerror = () => reject(new Error("Gagal memuat gambar."));
                img.src = src;
            });

        const getSelectedTemplate = () => {
            if (customTemplateUrl) return customTemplateUrl;
            return (
                templateSelectEl?.value ??
                "/twibbon-templates/ramadhan-kareem.svg"
            );
        };

        const drawRoundedRect = (
            ctx: CanvasRenderingContext2D,
            x: number,
            y: number,
            w: number,
            h: number,
            r: number,
        ) => {
            const radius = Math.min(r, w / 2, h / 2);
            ctx.beginPath();
            ctx.moveTo(x + radius, y);
            ctx.lineTo(x + w - radius, y);
            ctx.quadraticCurveTo(x + w, y, x + w, y + radius);
            ctx.lineTo(x + w, y + h - radius);
            ctx.quadraticCurveTo(x + w, y + h, x + w - radius, y + h);
            ctx.lineTo(x + radius, y + h);
            ctx.quadraticCurveTo(x, y + h, x, y + h - radius);
            ctx.lineTo(x, y + radius);
            ctx.quadraticCurveTo(x, y, x + radius, y);
            ctx.closePath();
        };

        const renderTwibbon = async () => {
            try {
                const photoFile = photoInputEl?.files?.[0];
                if (!photoFile) {
                    if (messageEl)
                        messageEl.textContent =
                            "Silakan upload foto terlebih dahulu.";
                    return;
                }
                if (!canvasEl) return;

                const size = Number(outputSizeEl?.value ?? "1080");
                canvasEl.width = size;
                canvasEl.height = size;
                const ctx = canvasEl.getContext("2d");
                if (!ctx) throw new Error("Canvas context tidak tersedia.");

                const photoUrl = URL.createObjectURL(photoFile);
                const photo = await loadImage(photoUrl);
                const template = await loadImage(getSelectedTemplate());

                const centerX = size / 2;
                const centerY = size / 2;
                const radius = size * 0.296;
                const zoom = Number(zoomEl?.value ?? "1.2");
                const offsetX = Number(offsetXEl?.value ?? "0") * (size / 1080);
                const offsetY = Number(offsetYEl?.value ?? "0") * (size / 1080);

                ctx.clearRect(0, 0, size, size);
                ctx.fillStyle = "#ffffff";
                ctx.fillRect(0, 0, size, size);

                const baseScale = Math.max(
                    (radius * 2) / photo.width,
                    (radius * 2) / photo.height,
                );
                const drawW = photo.width * baseScale * zoom;
                const drawH = photo.height * baseScale * zoom;
                const drawX = centerX - drawW / 2 + offsetX;
                const drawY = centerY - drawH / 2 + offsetY;

                if (circleCropEl?.checked) {
                    ctx.save();
                    ctx.beginPath();
                    ctx.arc(centerX, centerY, radius, 0, Math.PI * 2);
                    ctx.closePath();
                    ctx.clip();
                    ctx.drawImage(photo, drawX, drawY, drawW, drawH);
                    ctx.restore();
                } else {
                    ctx.drawImage(photo, drawX, drawY, drawW, drawH);
                }

                ctx.drawImage(template, 0, 0, size, size);

                const greetingText = (greetingTextEl?.value ?? "").trim();
                if (greetingText) {
                    const fontSize =
                        Number(greetingSizeEl?.value ?? "42") * (size / 1080);
                    const textY = size - 88 * (size / 1080);
                    ctx.font = `700 ${fontSize}px "Plus Jakarta Sans", sans-serif`;
                    ctx.textAlign = "center";
                    ctx.textBaseline = "middle";

                    if (greetingBgEl?.checked) {
                        const paddingX = 30 * (size / 1080);
                        const paddingY = 16 * (size / 1080);
                        const textWidth = ctx.measureText(greetingText).width;
                        const rectW = textWidth + paddingX * 2;
                        const rectH = fontSize + paddingY * 2;
                        const rectX = centerX - rectW / 2;
                        const rectY = textY - rectH / 2;
                        drawRoundedRect(
                            ctx,
                            rectX,
                            rectY,
                            rectW,
                            rectH,
                            18 * (size / 1080),
                        );
                        ctx.fillStyle = "rgba(15, 23, 42, 0.62)";
                        ctx.fill();
                    }

                    ctx.fillStyle = greetingColorEl?.value ?? "#ffffff";
                    ctx.fillText(greetingText, centerX, textY);
                }

                const outputData = canvasEl.toDataURL("image/png");
                if (downloadEl) {
                    downloadEl.href = outputData;
                    downloadEl.classList.remove("hidden");
                }
                if (messageEl) {
                    messageEl.textContent = customTemplateUrl
                        ? "Twibbon berhasil dirender dengan template custom."
                        : "Twibbon berhasil dirender dengan template bawaan.";
                }
            } catch (error) {
                if (messageEl)
                    messageEl.textContent = `Gagal render twibbon: ${error instanceof Error ? error.message : "Unknown error"}`;
            }
        };

        templateUploadEl?.addEventListener("change", () => {
            const file = templateUploadEl.files?.[0];
            if (!file) {
                customTemplateUrl = "";
                return;
            }
            customTemplateUrl = URL.createObjectURL(file);
            if (messageEl)
                messageEl.textContent =
                    "Template custom dipilih. Klik Render Twibbon.";
        });

        templateSelectEl?.addEventListener("change", () => {
            if (!templateUploadEl?.files?.length) {
                customTemplateUrl = "";
            }
            if (photoInputEl?.files?.[0]) {
                renderTwibbon();
            }
        });

        [
            zoomEl,
            offsetXEl,
            offsetYEl,
            outputSizeEl,
            circleCropEl,
            greetingTextEl,
            greetingColorEl,
            greetingSizeEl,
            greetingBgEl,
        ].forEach((el) => {
            el?.addEventListener("input", () => {
                if (photoInputEl?.files?.[0]) {
                    renderTwibbon();
                }
            });
        });

        document
            .getElementById("twibbonRenderBtn")
            ?.addEventListener("click", renderTwibbon);
        document
            .getElementById("twibbonResetBtn")
            ?.addEventListener("click", () => {
                if (zoomEl) zoomEl.value = "1.2";
                if (offsetXEl) offsetXEl.value = "0";
                if (offsetYEl) offsetYEl.value = "0";
                if (photoInputEl?.files?.[0]) {
                    renderTwibbon();
                }
            });
    </script>
</BaseLayout>
