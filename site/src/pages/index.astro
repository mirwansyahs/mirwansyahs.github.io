---
import { getCollection } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 6);
---

<MainLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm md:p-10">
		<p class="text-xs font-bold uppercase tracking-[0.16em] text-teal-700">Portfolio + Blog</p>
		<h1 class="mt-4 text-4xl font-black leading-tight text-slate-900 md:text-5xl">
			Irwansyah: Software Developer, Product Builder, and Tools Creator
		</h1>
		<p class="mt-4 max-w-3xl text-base leading-relaxed text-slate-600">
			Website ini berisi portfolio proyek, studi kasus implementasi, dan artikel original seputar web development,
			mobile apps, dan strategi SEO untuk produk digital. Fokus utamanya adalah membuat solusi yang cepat,
			reusable, dan benar-benar dipakai pengguna.
		</p>
		<div class="mt-6 flex flex-wrap gap-3">
			<a
				href="https://tools.irwansyah.my.id"
				target="_blank"
				rel="noopener noreferrer"
				class="rounded-xl bg-amber-400 px-5 py-3 text-sm font-bold text-slate-900 hover:bg-amber-300"
			>
				Explore Tools
			</a>
			<a href="/blog" class="rounded-xl border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-700 hover:bg-slate-100">
				Read Blog
			</a>
		</div>
	</section>

	<section class="mt-6 grid gap-4 md:grid-cols-3">
		<article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
			<h2 class="text-lg font-bold text-slate-900">Tech Stack</h2>
			<p class="mt-2 text-sm leading-relaxed text-slate-600">React, React Native, Astro, Tailwind, Node.js, Golang, PostgreSQL, dan workflow deployment containerized.</p>
		</article>
		<article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
			<h2 class="text-lg font-bold text-slate-900">Studi Kasus</h2>
			<p class="mt-2 text-sm leading-relaxed text-slate-600">Dari pengembangan Life Plan hingga utility tools, tiap artikel membahas keputusan produk dan implementasi teknis.</p>
		</article>
		<article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
			<h2 class="text-lg font-bold text-slate-900">Konten Original</h2>
			<p class="mt-2 text-sm leading-relaxed text-slate-600">Semua tulisan disusun dari pengalaman proyek nyata agar bermanfaat untuk developer, founder, dan tim produk.</p>
		</article>
	</section>

	<section class="mt-6 rounded-3xl border border-slate-200 bg-white p-6 shadow-sm md:p-8">
		<div class="flex items-center justify-between gap-3">
			<h2 class="text-2xl font-black text-slate-900">Artikel Terbaru</h2>
			<a href="/blog" class="text-sm font-semibold text-teal-700 hover:text-teal-800">Lihat Semua -></a>
		</div>
		<div class="mt-4 grid gap-3 md:grid-cols-2 xl:grid-cols-3">
			{
				posts.map((post) => (
					<a href={`/blog/${post.id}/`} class="rounded-2xl border border-slate-200 p-4 transition hover:-translate-y-0.5 hover:shadow-md">
						<p class="text-xs font-semibold uppercase tracking-[0.12em] text-slate-500">{post.data.pubDate.toLocaleDateString('id-ID')}</p>
						<h3 class="mt-2 text-base font-bold text-slate-900">{post.data.title}</h3>
						<p class="mt-2 text-sm text-slate-600">{post.data.description}</p>
					</a>
				))
			}
		</div>
	</section>
</MainLayout>
