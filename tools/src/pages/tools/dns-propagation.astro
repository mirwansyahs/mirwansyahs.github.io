---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
    title="DNS Propagation Checker - Irwansyah Tools"
    description="Cek propagasi DNS dari beberapa resolver publik untuk record A, AAAA, CNAME, MX, TXT, dan NS."
    canonicalPath="/tools/dns-propagation"
>
    <section
        class="rounded-3xl border border-slate-200 bg-white p-4 shadow-sm md:p-5"
    >
        <h1 class="text-2xl font-black text-slate-900 md:text-3xl">
            DNS Propagation Checker
        </h1>
        <p class="mt-1 text-sm text-slate-600">
            Bandingkan hasil DNS dari beberapa resolver publik untuk melihat
            status propagasi.
        </p>

        <div class="mt-3 grid gap-3 md:grid-cols-[minmax(0,1fr)_180px]">
            <input
                id="propDomain"
                type="text"
                class="w-full rounded-2xl border border-slate-300 p-3 font-mono text-sm"
                placeholder="contoh: example.com"
            />
            <select
                id="propType"
                class="rounded-2xl border border-slate-300 p-3 text-sm"
            >
                <option value="A">A</option>
                <option value="AAAA">AAAA</option>
                <option value="CNAME">CNAME</option>
                <option value="MX">MX</option>
                <option value="TXT">TXT</option>
                <option value="NS">NS</option>
            </select>
        </div>

        <div class="mt-3 flex flex-wrap gap-2">
            <button
                id="propCheckBtn"
                class="rounded-xl bg-teal-600 px-4 py-2 text-sm font-semibold text-white hover:bg-teal-700"
                >Check Propagation</button
            >
            <button
                id="propCopyJsonBtn"
                class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100"
                >Copy JSON</button
            >
            <button
                id="propExportTxtBtn"
                class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100"
                >Export .txt</button
            >
        </div>

        <p id="propMessage" class="mt-3 text-sm text-slate-600"></p>
        <pre
            id="propOutput"
            class="mt-3 overflow-x-auto rounded-2xl border border-slate-200 bg-slate-50 p-3 font-mono text-xs text-slate-700">
        </pre>
    </section>

    <script>
        const domainEl = document.getElementById(
            "propDomain",
        ) as HTMLInputElement | null;
        const typeEl = document.getElementById(
            "propType",
        ) as HTMLSelectElement | null;
        const messageEl = document.getElementById(
            "propMessage",
        ) as HTMLParagraphElement | null;
        const outputEl = document.getElementById(
            "propOutput",
        ) as HTMLPreElement | null;

        let lastResult: unknown = null;

        const resolvers = [
            { name: "Google DoH", url: "https://dns.google/resolve" },
            {
                name: "Cloudflare DoH",
                url: "https://cloudflare-dns.com/dns-query",
            },
            { name: "Quad9 DoH", url: "https://dns.quad9.net/dns-query" },
        ];

        const downloadTxt = (filename: string, text: string) => {
            const blob = new Blob([text], { type: "text/plain;charset=utf-8" });
            const url = URL.createObjectURL(blob);
            const link = document.createElement("a");
            link.href = url;
            link.download = filename;
            link.click();
            URL.revokeObjectURL(url);
        };

        const queryResolver = async (
            resolver: { name: string; url: string },
            domain: string,
            type: string,
        ) => {
            try {
                const endpoint = `${resolver.url}?name=${encodeURIComponent(domain)}&type=${encodeURIComponent(type)}`;
                const res = await fetch(endpoint, {
                    headers: { Accept: "application/dns-json" },
                });
                if (!res.ok) throw new Error(`HTTP ${res.status}`);
                const json = await res.json();
                const answers = (json.Answer ?? []) as Array<{ data?: string }>;
                return {
                    resolver: resolver.name,
                    success: true,
                    values: answers.map((x) => x.data ?? ""),
                };
            } catch (error) {
                return {
                    resolver: resolver.name,
                    success: false,
                    values: [] as string[],
                    error:
                        error instanceof Error
                            ? error.message
                            : "Unknown error",
                };
            }
        };

        document
            .getElementById("propCheckBtn")
            ?.addEventListener("click", async () => {
                const domain = (domainEl?.value ?? "").trim();
                const type = typeEl?.value ?? "A";
                if (!domain) {
                    if (messageEl)
                        messageEl.textContent = "Domain wajib diisi.";
                    return;
                }

                if (messageEl)
                    messageEl.textContent =
                        "Memproses DNS propagation check...";
                const results = await Promise.all(
                    resolvers.map((resolver) =>
                        queryResolver(resolver, domain, type),
                    ),
                );
                lastResult = {
                    domain,
                    type,
                    checkedAt: new Date().toISOString(),
                    results,
                };

                const lines: string[] = [
                    `Domain: ${domain}`,
                    `Type  : ${type}`,
                    "",
                ];
                results.forEach((item) => {
                    lines.push(
                        `[${item.resolver}] ${item.success ? "OK" : "ERROR"}`,
                    );
                    if (item.success) {
                        if (item.values.length === 0) {
                            lines.push("- (no answer)");
                        } else {
                            item.values.forEach((value) =>
                                lines.push(`- ${value}`),
                            );
                        }
                    } else {
                        lines.push(`- ${item.error ?? "request failed"}`);
                    }
                    lines.push("");
                });

                if (outputEl) outputEl.textContent = lines.join("\n");
                if (messageEl)
                    messageEl.textContent = "Propagation check selesai.";
            });

        document
            .getElementById("propCopyJsonBtn")
            ?.addEventListener("click", async () => {
                if (!lastResult) return;
                await navigator.clipboard.writeText(
                    JSON.stringify(lastResult, null, 2),
                );
                if (messageEl)
                    messageEl.textContent =
                        "JSON hasil propagation tersalin ke clipboard.";
            });

        document
            .getElementById("propExportTxtBtn")
            ?.addEventListener("click", () => {
                const domain = (domainEl?.value ?? "lookup").trim() || "lookup";
                const output = outputEl?.textContent?.trim() ?? "";
                if (!output) return;
                downloadTxt(`dns-propagation-${domain}.txt`, output);
                if (messageEl)
                    messageEl.textContent =
                        "Hasil propagation berhasil diexport ke .txt.";
            });
    </script>
</BaseLayout>
