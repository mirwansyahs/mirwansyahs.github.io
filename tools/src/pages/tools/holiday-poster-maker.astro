---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
    title="Template Poster Hari Besar - Irwansyah Tools"
    description="Buat poster cepat untuk Ramadhan, Idul Fitri, Natal, dan Tahun Baru, lalu download PNG."
    canonicalPath="/tools/holiday-poster-maker"
>
    <section
        class="rounded-3xl border border-slate-200 bg-white p-4 shadow-sm md:p-5"
    >
        <h1 class="text-2xl font-black text-slate-900 md:text-3xl">
            Template Poster Hari Besar
        </h1>
        <p class="mt-1 text-sm text-slate-600">
            Generator poster siap pakai untuk Ramadhan, Idul Fitri, Natal, dan
            Tahun Baru.
        </p>

        <div class="mt-4 grid gap-3 md:grid-cols-2">
            <label class="block text-sm">
                <span class="mb-1 block font-semibold text-slate-700"
                    >Tema Poster</span
                >
                <select
                    id="posterTheme"
                    class="w-full rounded-2xl border border-slate-300 p-2"
                >
                    <option value="ramadhan">Ramadhan</option>
                    <option value="idulfitri">Idul Fitri</option>
                    <option value="natal">Natal</option>
                    <option value="tahunbaru">Tahun Baru</option>
                </select>
            </label>
            <label class="block text-sm">
                <span class="mb-1 block font-semibold text-slate-700"
                    >Ukuran</span
                >
                <select
                    id="posterSize"
                    class="w-full rounded-2xl border border-slate-300 p-2"
                >
                    <option value="1080">1080 x 1080</option>
                    <option value="1350">1080 x 1350</option>
                </select>
            </label>
        </div>

        <div class="mt-3 grid gap-3 md:grid-cols-2">
            <label class="block text-sm md:col-span-2">
                <span class="mb-1 block font-semibold text-slate-700"
                    >Judul</span
                >
                <input
                    id="posterTitle"
                    type="text"
                    value="Selamat Menjalankan Ibadah Puasa"
                    class="w-full rounded-2xl border border-slate-300 p-2"
                />
            </label>
            <label class="block text-sm">
                <span class="mb-1 block font-semibold text-slate-700"
                    >Subjudul</span
                >
                <input
                    id="posterSubtitle"
                    type="text"
                    value="Semoga Ramadhan penuh berkah"
                    class="w-full rounded-2xl border border-slate-300 p-2"
                />
            </label>
            <label class="block text-sm">
                <span class="mb-1 block font-semibold text-slate-700"
                    >Footer</span
                >
                <input
                    id="posterFooter"
                    type="text"
                    value="Dari Tim Kami"
                    class="w-full rounded-2xl border border-slate-300 p-2"
                />
            </label>
        </div>

        <div class="mt-4 flex flex-wrap gap-2">
            <button
                id="posterRenderBtn"
                class="rounded-xl bg-teal-600 px-4 py-2 text-sm font-semibold text-white hover:bg-teal-700"
                >Render Poster</button
            >
            <a
                id="posterDownloadBtn"
                class="hidden rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100"
                download="poster-hari-besar.png">Download PNG</a
            >
        </div>

        <p id="posterMessage" class="mt-2 text-sm text-slate-600"></p>

        <div class="mt-3 rounded-2xl border border-slate-200 bg-slate-50 p-3">
            <canvas
                id="posterCanvas"
                width="1080"
                height="1080"
                class="mx-auto w-full max-w-[560px] rounded-xl border border-slate-200 bg-white"
            ></canvas>
        </div>
    </section>

    <script>
        const themeEl = document.getElementById(
            "posterTheme",
        ) as HTMLSelectElement | null;
        const sizeEl = document.getElementById(
            "posterSize",
        ) as HTMLSelectElement | null;
        const titleEl = document.getElementById(
            "posterTitle",
        ) as HTMLInputElement | null;
        const subtitleEl = document.getElementById(
            "posterSubtitle",
        ) as HTMLInputElement | null;
        const footerEl = document.getElementById(
            "posterFooter",
        ) as HTMLInputElement | null;
        const canvasEl = document.getElementById(
            "posterCanvas",
        ) as HTMLCanvasElement | null;
        const messageEl = document.getElementById(
            "posterMessage",
        ) as HTMLParagraphElement | null;
        const downloadEl = document.getElementById(
            "posterDownloadBtn",
        ) as HTMLAnchorElement | null;

        const themeConfig: Record<
            string,
            {
                gradient: [string, string];
                accent: string;
                icon: string;
                defaultTitle: string;
                defaultSub: string;
            }
        > = {
            ramadhan: {
                gradient: ["#064e3b", "#10b981"],
                accent: "#fde68a",
                icon: "🌙",
                defaultTitle: "Selamat Menjalankan Ibadah Puasa",
                defaultSub: "Semoga Ramadhan penuh berkah",
            },
            idulfitri: {
                gradient: ["#065f46", "#34d399"],
                accent: "#fef3c7",
                icon: "🕌",
                defaultTitle: "Selamat Hari Raya Idul Fitri",
                defaultSub: "Mohon maaf lahir dan batin",
            },
            natal: {
                gradient: ["#7f1d1d", "#ef4444"],
                accent: "#fef2f2",
                icon: "🎄",
                defaultTitle: "Selamat Hari Natal",
                defaultSub: "Damai dan sukacita untuk kita semua",
            },
            tahunbaru: {
                gradient: ["#1e1b4b", "#4f46e5"],
                accent: "#dbeafe",
                icon: "🎆",
                defaultTitle: "Selamat Tahun Baru",
                defaultSub: "Harapan baru, semangat baru",
            },
        };

        const drawPoster = () => {
            if (!canvasEl) return;
            const size = Number(sizeEl?.value ?? 1080);
            const theme = themeEl?.value ?? "ramadhan";
            const config = themeConfig[theme] ?? themeConfig.ramadhan;

            const width = 1080;
            const height = size === 1350 ? 1350 : 1080;
            canvasEl.width = width;
            canvasEl.height = height;

            const ctx = canvasEl.getContext("2d");
            if (!ctx) return;

            const gradient = ctx.createLinearGradient(0, 0, width, height);
            gradient.addColorStop(0, config.gradient[0]);
            gradient.addColorStop(1, config.gradient[1]);
            ctx.fillStyle = gradient;
            ctx.fillRect(0, 0, width, height);

            ctx.globalAlpha = 0.12;
            for (let i = 0; i < 22; i += 1) {
                ctx.beginPath();
                ctx.fillStyle = config.accent;
                ctx.arc(
                    (i * 97) % width,
                    (i * 173) % height,
                    80 + (i % 5) * 16,
                    0,
                    Math.PI * 2,
                );
                ctx.fill();
            }
            ctx.globalAlpha = 1;

            ctx.fillStyle = "rgba(255,255,255,0.14)";
            ctx.fillRect(72, 90, width - 144, height - 180);

            const title = (titleEl?.value ?? "").trim() || config.defaultTitle;
            const subtitle =
                (subtitleEl?.value ?? "").trim() || config.defaultSub;
            const footer = (footerEl?.value ?? "").trim() || "Dari Tim Kami";

            ctx.textAlign = "center";
            ctx.fillStyle = "#ffffff";
            ctx.font = "700 90px serif";
            ctx.fillText(config.icon, width / 2, 250);

            ctx.font = "800 62px system-ui";
            wrapText(ctx, title, width / 2, 390, width - 220, 78);

            ctx.fillStyle = "#f8fafc";
            ctx.font = "500 38px system-ui";
            wrapText(ctx, subtitle, width / 2, 620, width - 220, 52);

            ctx.fillStyle = config.accent;
            ctx.font = "600 30px system-ui";
            ctx.fillText(footer, width / 2, height - 120);

            if (downloadEl) {
                downloadEl.href = canvasEl.toDataURL("image/png");
                downloadEl.classList.remove("hidden");
            }
            if (messageEl) messageEl.textContent = "Poster berhasil dirender.";
        };

        const wrapText = (
            ctx: CanvasRenderingContext2D,
            text: string,
            centerX: number,
            startY: number,
            maxWidth: number,
            lineHeight: number,
        ) => {
            const words = text.split(" ");
            const lines: string[] = [];
            let current = "";

            words.forEach((word) => {
                const test = `${current}${word} `;
                if (ctx.measureText(test).width > maxWidth && current) {
                    lines.push(current.trim());
                    current = `${word} `;
                } else {
                    current = test;
                }
            });
            if (current.trim()) lines.push(current.trim());

            lines.forEach((line, index) => {
                ctx.fillText(line, centerX, startY + index * lineHeight);
            });
        };

        document
            .getElementById("posterRenderBtn")
            ?.addEventListener("click", drawPoster);
        themeEl?.addEventListener("change", () => {
            const theme = themeEl.value;
            const config = themeConfig[theme] ?? themeConfig.ramadhan;
            if (titleEl && !titleEl.value.trim())
                titleEl.value = config.defaultTitle;
            if (subtitleEl && !subtitleEl.value.trim())
                subtitleEl.value = config.defaultSub;
            drawPoster();
        });

        drawPoster();
    </script>
</BaseLayout>
