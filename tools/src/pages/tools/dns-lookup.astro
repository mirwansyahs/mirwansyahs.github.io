---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
    title="DNS Lookup Toolbox - Irwansyah Tools"
    description="Tool networking untuk lookup record DNS seperti TXT, CNAME, AAAA, PTR, dan SOA langsung dari browser."
    canonicalPath="/tools/dns-lookup"
>
    <section
        class="rounded-3xl border border-slate-200 bg-white p-4 shadow-sm md:p-5"
    >
        <h1 class="text-2xl font-black text-slate-900 md:text-3xl">
            DNS Lookup Toolbox
        </h1>
        <p class="mt-1 text-sm text-slate-600">
            Lookup record DNS tambahan untuk kebutuhan troubleshooting
            networking.
        </p>

        <div class="mt-3 grid gap-3 md:grid-cols-[minmax(0,1fr)_180px_220px]">
            <input
                id="dnsDomain"
                type="text"
                class="w-full rounded-2xl border border-slate-300 p-3 font-mono text-sm"
                placeholder="contoh: example.com"
            />
            <select
                id="dnsType"
                class="rounded-2xl border border-slate-300 p-3 text-sm"
            >
                <option value="TXT">TXT</option>
                <option value="CNAME">CNAME</option>
                <option value="AAAA">AAAA</option>
                <option value="PTR">PTR</option>
                <option value="SOA">SOA</option>
            </select>
            <select
                id="dnsProvider"
                class="rounded-2xl border border-slate-300 p-3 text-sm"
            >
                <option value="cloudflare">Cloudflare DNS</option>
                <option value="google">Google DNS</option>
            </select>
        </div>

        <div class="mt-3 flex flex-wrap gap-2">
            <button
                id="dnsLookupBtn"
                class="rounded-xl bg-teal-600 px-4 py-2 text-sm font-semibold text-white hover:bg-teal-700"
                >Lookup DNS</button
            >
            <button
                id="dnsCopyJsonBtn"
                class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100"
                >Copy JSON</button
            >
            <button
                id="dnsExportTxtBtn"
                class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100"
                >Export .txt</button
            >
        </div>
        <p id="dnsMessage" class="mt-3 text-sm text-slate-600"></p>
        <pre
            id="dnsOutput"
            class="mt-3 overflow-x-auto rounded-2xl border border-slate-200 bg-slate-50 p-3 font-mono text-xs text-slate-700">
        </pre>
    </section>

    <script>
        const domainEl = document.getElementById(
            "dnsDomain",
        ) as HTMLInputElement | null;
        const typeEl = document.getElementById(
            "dnsType",
        ) as HTMLSelectElement | null;
        const providerEl = document.getElementById(
            "dnsProvider",
        ) as HTMLSelectElement | null;
        const messageEl = document.getElementById(
            "dnsMessage",
        ) as HTMLParagraphElement | null;
        const outputEl = document.getElementById(
            "dnsOutput",
        ) as HTMLPreElement | null;
        let lastResult: unknown = null;

        const downloadTxt = (filename: string, text: string) => {
            const blob = new Blob([text], { type: "text/plain;charset=utf-8" });
            const url = URL.createObjectURL(blob);
            const link = document.createElement("a");
            link.href = url;
            link.download = filename;
            link.click();
            URL.revokeObjectURL(url);
        };

        document
            .getElementById("dnsLookupBtn")
            ?.addEventListener("click", async () => {
                try {
                    const domain = (domainEl?.value ?? "").trim();
                    const type = typeEl?.value ?? "TXT";
                    const provider = providerEl?.value ?? "cloudflare";

                    if (!domain) {
                        if (messageEl)
                            messageEl.textContent = "Domain wajib diisi.";
                        return;
                    }

                    const endpoint =
                        provider === "google"
                            ? `https://dns.google/resolve?name=${encodeURIComponent(domain)}&type=${encodeURIComponent(type)}`
                            : `https://cloudflare-dns.com/dns-query?name=${encodeURIComponent(domain)}&type=${encodeURIComponent(type)}`;

                    if (messageEl)
                        messageEl.textContent = `Memproses ${type} lookup...`;
                    const res = await fetch(endpoint, {
                        headers: { Accept: "application/dns-json" },
                    });
                    if (!res.ok)
                        throw new Error(`DNS request gagal (${res.status})`);

                    const data = await res.json();
                    lastResult = data;
                    const answers = (data.Answer ?? []) as Array<{
                        data?: string;
                        TTL?: number;
                        type?: number;
                    }>;
                    if (answers.length === 0) {
                        if (outputEl)
                            outputEl.textContent = `${type} record tidak ditemukan.`;
                        if (messageEl)
                            messageEl.textContent =
                                "Lookup selesai. Record tidak ditemukan.";
                        return;
                    }

                    const lines = answers.map(
                        (item, index) =>
                            `#${index + 1} ${item.data ?? ""} TTL=${item.TTL ?? "-"}`,
                    );
                    if (outputEl) outputEl.textContent = lines.join("\n");
                    if (messageEl)
                        messageEl.textContent = `Lookup selesai. Ditemukan ${answers.length} record.`;
                } catch (error) {
                    if (outputEl) outputEl.textContent = "";
                    if (messageEl)
                        messageEl.textContent = `Gagal lookup DNS: ${error instanceof Error ? error.message : "Unknown error"}`;
                }
            });

        document
            .getElementById("dnsCopyJsonBtn")
            ?.addEventListener("click", async () => {
                if (!lastResult) return;
                await navigator.clipboard.writeText(
                    JSON.stringify(lastResult, null, 2),
                );
                if (messageEl)
                    messageEl.textContent =
                        "JSON hasil lookup tersalin ke clipboard.";
            });

        document
            .getElementById("dnsExportTxtBtn")
            ?.addEventListener("click", () => {
                const domain = (domainEl?.value ?? "lookup").trim() || "lookup";
                const type = typeEl?.value ?? "TXT";
                const output = outputEl?.textContent?.trim() ?? "";
                if (!output) return;
                downloadTxt(
                    `dns-lookup-${type.toLowerCase()}-${domain}.txt`,
                    output,
                );
                if (messageEl)
                    messageEl.textContent =
                        "Hasil lookup berhasil diexport ke .txt.";
            });
    </script>
</BaseLayout>
