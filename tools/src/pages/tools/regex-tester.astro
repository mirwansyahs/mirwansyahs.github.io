---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
    title="Regex Tester - Irwansyah Tools"
    description="Uji regular expression dengan flags, lihat semua match, dan debug pola regex untuk validasi data dengan cepat."
    canonicalPath="/tools/regex-tester"
>
    <section
        class="rounded-3xl border border-slate-200 bg-white p-4 shadow-sm md:p-5"
    >
        <h1 class="text-2xl font-black text-slate-900 md:text-3xl">
            Regex Tester
        </h1>
        <p class="mt-1 text-sm text-slate-600">
            Tes pola regex terhadap text input, lengkap dengan flags dan hasil
            match.
        </p>

        <div class="mt-3 grid gap-3 md:grid-cols-2">
            <label class="block">
                <span class="mb-2 block text-sm font-semibold text-slate-700"
                    >Regex Pattern</span
                >
                <input
                    id="regexPattern"
                    type="text"
                    class="w-full rounded-2xl border border-slate-300 p-3 font-mono text-sm"
                    placeholder="contoh: [a-z]+@[a-z]+\\.[a-z]{2,}"
                />
            </label>
            <label class="block">
                <span class="mb-2 block text-sm font-semibold text-slate-700"
                    >Flags</span
                >
                <input
                    id="regexFlags"
                    type="text"
                    class="w-full rounded-2xl border border-slate-300 p-3 font-mono text-sm"
                    placeholder="gim"
                />
            </label>
        </div>

        <label class="mt-3 block">
            <span class="mb-2 block text-sm font-semibold text-slate-700"
                >Text Input</span
            >
            <textarea
                id="regexInput"
                class="h-44 w-full rounded-2xl border border-slate-300 p-3 font-mono text-sm md:h-56"
                placeholder="Masukkan text untuk dites..."></textarea>
        </label>

        <div class="mt-3 flex flex-wrap gap-2">
            <button
                id="regexRunBtn"
                class="rounded-xl bg-teal-600 px-4 py-2 text-sm font-semibold text-white hover:bg-teal-700"
                >Run Test</button
            >
            <button
                id="regexSampleBtn"
                class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100"
                >Use Sample</button
            >
        </div>

        <p id="regexMessage" class="mt-3 text-sm text-slate-600"></p>
        <pre
            id="regexOutput"
            class="mt-3 overflow-x-auto rounded-2xl border border-slate-200 bg-slate-50 p-3 font-mono text-xs text-slate-700">
        </pre>
    </section>

    <script>
        const patternEl = document.getElementById(
            "regexPattern",
        ) as HTMLInputElement | null;
        const flagsEl = document.getElementById(
            "regexFlags",
        ) as HTMLInputElement | null;
        const inputEl = document.getElementById(
            "regexInput",
        ) as HTMLTextAreaElement | null;
        const outputEl = document.getElementById(
            "regexOutput",
        ) as HTMLPreElement | null;
        const messageEl = document.getElementById(
            "regexMessage",
        ) as HTMLParagraphElement | null;

        const runRegex = () => {
            try {
                const pattern = patternEl?.value ?? "";
                const flags = flagsEl?.value ?? "g";
                const text = inputEl?.value ?? "";
                const regex = new RegExp(pattern, flags);
                const matches = [...text.matchAll(regex)];

                if (matches.length === 0) {
                    if (outputEl) outputEl.textContent = "Tidak ada match.";
                    if (messageEl)
                        messageEl.textContent =
                            "Regex valid, tetapi tidak ada hasil yang cocok.";
                    return;
                }

                const lines = matches.map(
                    (match, index) =>
                        `#${index + 1} index=${match.index ?? -1} value=${match[0]}`,
                );
                if (outputEl) outputEl.textContent = lines.join("\n");
                if (messageEl)
                    messageEl.textContent = `Regex valid. Total match: ${matches.length}.`;
            } catch (error) {
                if (outputEl) outputEl.textContent = "";
                if (messageEl)
                    messageEl.textContent = `Regex error: ${error instanceof Error ? error.message : "Unknown error"}`;
            }
        };

        document
            .getElementById("regexRunBtn")
            ?.addEventListener("click", runRegex);
        document
            .getElementById("regexSampleBtn")
            ?.addEventListener("click", () => {
                if (patternEl) patternEl.value = "[a-z]+@[a-z]+\\\\.[a-z]{2,}";
                if (flagsEl) flagsEl.value = "gi";
                if (inputEl) {
                    inputEl.value =
                        "Email valid: hello@example.com\nEmail lain: dev@site.id\nTidak valid: user@@mail";
                }
                runRegex();
            });
    </script>
</BaseLayout>
