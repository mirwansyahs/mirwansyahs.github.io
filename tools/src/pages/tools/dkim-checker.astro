---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
    title="DKIM Checker - Irwansyah Tools"
    description="Cek DKIM TXT record berdasarkan selector dan domain untuk memastikan konfigurasi email authentication aktif."
    canonicalPath="/tools/dkim-checker"
>
    <section
        class="rounded-3xl border border-slate-200 bg-white p-4 shadow-sm md:p-5"
    >
        <h1 class="text-2xl font-black text-slate-900 md:text-3xl">
            DKIM Checker
        </h1>
        <p class="mt-1 text-sm text-slate-600">
            Periksa record <code>selector._domainkey.domain</code> dan validasi format
            dasar DKIM.
        </p>

        <div class="mt-3 grid gap-3 md:grid-cols-2">
            <input
                id="dkimSelector"
                type="text"
                class="w-full rounded-2xl border border-slate-300 p-3 font-mono text-sm"
                placeholder="selector, contoh: google"
            />
            <input
                id="dkimDomain"
                type="text"
                class="w-full rounded-2xl border border-slate-300 p-3 font-mono text-sm"
                placeholder="domain, contoh: yourdomain.com"
            />
        </div>

        <div class="mt-3 flex flex-wrap gap-2">
            <button
                id="dkimCheckBtn"
                class="rounded-xl bg-teal-600 px-4 py-2 text-sm font-semibold text-white hover:bg-teal-700"
                >Check DKIM</button
            >
            <button
                id="dkimCopyJsonBtn"
                class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100"
                >Copy JSON</button
            >
            <button
                id="dkimExportTxtBtn"
                class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100"
                >Export .txt</button
            >
        </div>

        <p id="dkimMessage" class="mt-3 text-sm text-slate-600"></p>
        <pre
            id="dkimOutput"
            class="mt-3 overflow-x-auto rounded-2xl border border-slate-200 bg-slate-50 p-3 font-mono text-xs text-slate-700">
        </pre>
    </section>

    <script>
        const selectorEl = document.getElementById(
            "dkimSelector",
        ) as HTMLInputElement | null;
        const domainEl = document.getElementById(
            "dkimDomain",
        ) as HTMLInputElement | null;
        const messageEl = document.getElementById(
            "dkimMessage",
        ) as HTMLParagraphElement | null;
        const outputEl = document.getElementById(
            "dkimOutput",
        ) as HTMLPreElement | null;
        let lastResult: unknown = null;

        const downloadTxt = (filename: string, text: string) => {
            const blob = new Blob([text], { type: "text/plain;charset=utf-8" });
            const url = URL.createObjectURL(blob);
            const link = document.createElement("a");
            link.href = url;
            link.download = filename;
            link.click();
            URL.revokeObjectURL(url);
        };

        document
            .getElementById("dkimCheckBtn")
            ?.addEventListener("click", async () => {
                try {
                    const selector = (selectorEl?.value ?? "").trim();
                    const domain = (domainEl?.value ?? "").trim().toLowerCase();
                    if (!selector || !domain) {
                        if (messageEl)
                            messageEl.textContent =
                                "Selector dan domain wajib diisi.";
                        return;
                    }

                    const host = `${selector}._domainkey.${domain}`;
                    if (messageEl)
                        messageEl.textContent = "Memproses DKIM check...";
                    const endpoint = `https://dns.google/resolve?name=${encodeURIComponent(host)}&type=TXT`;
                    const res = await fetch(endpoint, {
                        headers: { Accept: "application/dns-json" },
                    });
                    if (!res.ok)
                        throw new Error(`DNS request gagal (${res.status})`);

                    const data = await res.json();
                    lastResult = data;
                    const answers = (data.Answer ?? []) as Array<{
                        data?: string;
                        TTL?: number;
                    }>;
                    if (answers.length === 0) {
                        if (outputEl)
                            outputEl.textContent =
                                "DKIM TXT record tidak ditemukan.";
                        if (messageEl)
                            messageEl.textContent =
                                "Check selesai. Record belum terpublikasi.";
                        return;
                    }

                    const joined = answers
                        .map((a) => (a.data ?? "").replace(/^"|"$/g, ""))
                        .join(" ");
                    const hasVersion = /v=DKIM1/i.test(joined);
                    const hasPublicKey = /p=([^;\s]+)/i.test(joined);

                    const summary = [
                        `Host           : ${host}`,
                        `v=DKIM1 found  : ${hasVersion ? "yes" : "no"}`,
                        `public key (p) : ${hasPublicKey ? "yes" : "no"}`,
                        "",
                        "Raw TXT record:",
                        joined,
                    ];

                    if (outputEl) outputEl.textContent = summary.join("\n");
                    if (messageEl)
                        messageEl.textContent = "DKIM check selesai.";
                } catch (error) {
                    if (outputEl) outputEl.textContent = "";
                    if (messageEl)
                        messageEl.textContent = `Gagal check DKIM: ${error instanceof Error ? error.message : "Unknown error"}`;
                }
            });

        document
            .getElementById("dkimCopyJsonBtn")
            ?.addEventListener("click", async () => {
                if (!lastResult) return;
                await navigator.clipboard.writeText(
                    JSON.stringify(lastResult, null, 2),
                );
                if (messageEl)
                    messageEl.textContent =
                        "JSON hasil check tersalin ke clipboard.";
            });

        document
            .getElementById("dkimExportTxtBtn")
            ?.addEventListener("click", () => {
                const domain = (domainEl?.value ?? "lookup").trim() || "lookup";
                const selector =
                    (selectorEl?.value ?? "selector").trim() || "selector";
                const output = outputEl?.textContent?.trim() ?? "";
                if (!output) return;
                downloadTxt(`dkim-check-${selector}-${domain}.txt`, output);
                if (messageEl)
                    messageEl.textContent =
                        "Hasil check berhasil diexport ke .txt.";
            });
    </script>
</BaseLayout>
