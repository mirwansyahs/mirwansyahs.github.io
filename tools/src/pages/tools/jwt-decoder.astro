---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
    title="JWT Decoder - Irwansyah Tools"
    description="Decode JWT header dan payload (tanpa verifikasi signature) untuk debugging auth token secara cepat di browser."
    canonicalPath="/tools/jwt-decoder"
>
    <section
        class="rounded-3xl border border-slate-200 bg-white p-4 shadow-sm md:p-5"
    >
        <h1 class="text-2xl font-black text-slate-900 md:text-3xl">
            JWT Decoder
        </h1>
        <p class="mt-1 text-sm text-slate-600">
            Decode token JWT untuk melihat <code>header</code> dan <code
                >payload</code
            >. Signature tidak diverifikasi.
        </p>

        <label class="mt-3 block">
            <span class="mb-2 block text-sm font-semibold text-slate-700"
                >JWT Token</span
            >
            <textarea
                id="jwtInput"
                class="h-36 w-full rounded-2xl border border-slate-300 p-3 font-mono text-xs md:h-44"
                placeholder="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
            ></textarea>
        </label>

        <div class="mt-3 flex flex-wrap gap-2">
            <button
                id="jwtDecodeBtn"
                class="rounded-xl bg-teal-600 px-4 py-2 text-sm font-semibold text-white hover:bg-teal-700"
                >Decode JWT</button
            >
            <button
                id="jwtSampleBtn"
                class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100"
                >Use Sample</button
            >
        </div>

        <p id="jwtMessage" class="mt-3 text-sm text-slate-600"></p>

        <div class="mt-3 grid gap-3 md:grid-cols-2">
            <label class="block">
                <span class="mb-2 block text-sm font-semibold text-slate-700"
                    >Header</span
                >
                <textarea
                    id="jwtHeader"
                    class="h-44 w-full rounded-2xl border border-slate-300 p-3 font-mono text-xs"
                    readonly></textarea>
            </label>
            <label class="block">
                <span class="mb-2 block text-sm font-semibold text-slate-700"
                    >Payload</span
                >
                <textarea
                    id="jwtPayload"
                    class="h-44 w-full rounded-2xl border border-slate-300 p-3 font-mono text-xs"
                    readonly></textarea>
            </label>
        </div>
    </section>

    <script>
        const inputEl = document.getElementById(
            "jwtInput",
        ) as HTMLTextAreaElement | null;
        const headerEl = document.getElementById(
            "jwtHeader",
        ) as HTMLTextAreaElement | null;
        const payloadEl = document.getElementById(
            "jwtPayload",
        ) as HTMLTextAreaElement | null;
        const messageEl = document.getElementById(
            "jwtMessage",
        ) as HTMLParagraphElement | null;

        const decodeBase64Url = (value: string) => {
            const normalized = value.replace(/-/g, "+").replace(/_/g, "/");
            const padded = normalized.padEnd(
                normalized.length + ((4 - (normalized.length % 4)) % 4),
                "=",
            );
            return decodeURIComponent(escape(atob(padded)));
        };

        const decodeJwt = () => {
            try {
                const token = (inputEl?.value ?? "").trim();
                const parts = token.split(".");
                if (parts.length < 2) {
                    if (messageEl)
                        messageEl.textContent =
                            "JWT tidak valid. Format harus header.payload.signature.";
                    return;
                }

                const header = JSON.parse(decodeBase64Url(parts[0]));
                const payload = JSON.parse(decodeBase64Url(parts[1]));
                if (headerEl) headerEl.value = JSON.stringify(header, null, 2);
                if (payloadEl)
                    payloadEl.value = JSON.stringify(payload, null, 2);
                if (messageEl)
                    messageEl.textContent =
                        "JWT berhasil di-decode (signature tidak diverifikasi).";
            } catch {
                if (messageEl)
                    messageEl.textContent =
                        "Gagal decode JWT. Pastikan token valid.";
            }
        };

        document
            .getElementById("jwtDecodeBtn")
            ?.addEventListener("click", decodeJwt);

        document
            .getElementById("jwtSampleBtn")
            ?.addEventListener("click", () => {
                if (!inputEl) return;
                inputEl.value =
                    "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMjM0NTY3ODkwIiwibmFtZSI6Iklyd2Fuc3lhaCIsImlhdCI6MTcxMDAwMDAwMH0.signature";
                decodeJwt();
            });
    </script>
</BaseLayout>
