---
import "../styles/global.css";
import { NAV_ITEMS, SITE } from "../config/site";

interface Props {
    title?: string;
    description?: string;
    canonicalPath?: string;
}

const {
    title = SITE.title,
    description = SITE.description,
    canonicalPath = Astro.url.pathname,
} = Astro.props;

const canonical = new URL(canonicalPath, SITE.url).toString();
const isToolsPage = canonicalPath.startsWith("/tools/");
const adsenseClient = import.meta.env.PUBLIC_GOOGLE_ADSENSE_CLIENT;
const DESKTOP_PRIMARY_NAV_COUNT = 4;
const isActiveNav = (href: string) =>
    href === "/"
        ? canonicalPath === "/"
        : canonicalPath === href || canonicalPath.startsWith(`${href}/`);
const primaryNavItems = NAV_ITEMS.slice(0, DESKTOP_PRIMARY_NAV_COUNT);
const overflowNavItems = NAV_ITEMS.slice(DESKTOP_PRIMARY_NAV_COUNT);
const hasOverflowNav = overflowNavItems.length > 0;
const isOverflowActive = overflowNavItems.some((item) =>
    isActiveNav(item.href),
);
const footerToolItems = NAV_ITEMS.filter((item) =>
    item.href.startsWith("/tools/"),
);
type NavItem = (typeof NAV_ITEMS)[number];
const getFooterCategory = (item: NavItem) => {
    if (
        [
            "/tools/caption-generator",
            "/tools/caption-hashtag-generator",
            "/tools/paraphraser",
            "/tools/headline-generator",
            "/tools/emoji-text-style",
            "/tools/holiday-greeting-generator",
        ].includes(item.href)
    ) {
        return "Content";
    }

    if (["/tools/qr-generator", "/tools/qr-link-tools"].includes(item.href)) {
        return "Marketing";
    }

    if (
        [
            "/tools/twibbon-maker",
            "/tools/holiday-poster-maker",
            "/tools/image-compress",
            "/tools/image-to-pdf",
            "/tools/pdf-to-image",
            "/tools/pdf-compress",
            "/tools/image-to-ascii",
        ].includes(item.href)
    ) {
        return "Media";
    }

    if (
        [
            "/tools/dns-propagation",
            "/tools/dns-lookup",
            "/tools/mx-lookup",
            "/tools/a-lookup",
            "/tools/caa-checker",
            "/tools/srv-checker",
            "/tools/cname-lookup",
            "/tools/txt-lookup",
            "/tools/ns-lookup",
        ].includes(item.href)
    ) {
        return "Networking";
    }

    if (
        [
            "/tools/spf-checker",
            "/tools/dkim-checker",
            "/tools/dkim-generator",
            "/tools/dmarc-checker",
        ].includes(item.href)
    ) {
        return "Email Auth";
    }

    if (
        [
            "/tools/json-formatter-validator",
            "/tools/json-viewer",
            "/tools/regex-tester",
            "/tools/timestamp-converter",
            "/tools/uuid-generator",
        ].includes(item.href)
    ) {
        return "Data";
    }

    if (
        [
            "/tools/html-encode-decode",
            "/tools/base64-encode-decode",
            "/tools/url-encode-decode",
            "/tools/base64-to-image",
        ].includes(item.href)
    ) {
        return "Encoding";
    }

    if (
        [
            "/tools/jwt-decoder",
            "/tools/aes-encrypt-decrypt",
            "/tools/hash-generator",
        ].includes(item.href)
    ) {
        return "Security";
    }

    return "Lainnya";
};
const footerCategoryOrder = [
    "Content",
    "Marketing",
    "Media",
    "Networking",
    "Email Auth",
    "Data",
    "Encoding",
    "Security",
    "Lainnya",
];
const footerToolGroups = footerCategoryOrder
    .map((category) => ({
        category,
        items: footerToolItems.filter(
            (item) => getFooterCategory(item) === category,
        ),
    }))
    .filter((group) => group.items.length > 0);
const jsonLd = {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: SITE.name,
    url: SITE.url,
    potentialAction: {
        "@type": "SearchAction",
        target: `${SITE.url}/?q={search_term_string}`,
        "query-input": "required name=search_term_string",
    },
};
const pageJsonLd = {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: title,
    description,
    url: canonical,
    inLanguage: "id-ID",
    isPartOf: {
        "@type": "WebSite",
        name: SITE.name,
        url: SITE.url,
    },
};
const toolJsonLd = isToolsPage
    ? {
          "@context": "https://schema.org",
          "@type": "WebApplication",
          name: title,
          applicationCategory: "DeveloperApplication",
          operatingSystem: "Web Browser",
          description,
          url: canonical,
          offers: {
              "@type": "Offer",
              price: "0",
              priceCurrency: "USD",
          },
      }
    : null;

const toolSlug = isToolsPage
    ? canonicalPath.replace(/^\/tools\//, "").replace(/\/+$/, "")
    : "";
const currentToolItem = NAV_ITEMS.find((item) => item.href === canonicalPath);
const currentToolName =
    currentToolItem?.label ?? title.replace(/\s*-\s*Irwansyah Tools\s*$/i, "");
const currentToolCategory = currentToolItem
    ? getFooterCategory(currentToolItem)
    : "Lainnya";

