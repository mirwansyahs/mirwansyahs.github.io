---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
    title="Title & Headline Generator - Irwansyah Tools"
    description="Generate ide judul artikel, headline konten, dan hook copywriting untuk SEO dan sosial media."
    canonicalPath="/tools/headline-generator"
>
    <section
        class="rounded-3xl border border-slate-200 bg-white p-4 shadow-sm md:p-5"
    >
        <h1 class="text-2xl font-black text-slate-900 md:text-3xl">
            Title / Headline Generator
        </h1>
        <p class="mt-1 text-sm text-slate-600">
            Cari judul artikel, headline iklan, dan hook konten yang lebih
            menarik.
        </p>

        <div class="mt-4 grid gap-3 md:grid-cols-2">
            <label class="block text-sm md:col-span-2">
                <span class="mb-1 block font-semibold text-slate-700"
                    >Topik Utama</span
                >
                <input
                    id="headlineTopic"
                    type="text"
                    placeholder="Contoh: tips belajar coding"
                    class="w-full rounded-2xl border border-slate-300 p-2"
                />
            </label>
            <label class="block text-sm">
                <span class="mb-1 block font-semibold text-slate-700"
                    >Kata Kunci</span
                >
                <input
                    id="headlineKeyword"
                    type="text"
                    placeholder="Contoh: pemula"
                    class="w-full rounded-2xl border border-slate-300 p-2"
                />
            </label>
            <label class="block text-sm">
                <span class="mb-1 block font-semibold text-slate-700"
                    >Target Pembaca</span
                >
                <input
                    id="headlineAudience"
                    type="text"
                    placeholder="Contoh: mahasiswa"
                    class="w-full rounded-2xl border border-slate-300 p-2"
                />
            </label>
        </div>

        <div class="mt-3 grid gap-3 md:grid-cols-3">
            <label class="block text-sm">
                <span class="mb-1 block font-semibold text-slate-700"
                    >Style</span
                >
                <select
                    id="headlineStyle"
                    class="w-full rounded-2xl border border-slate-300 p-2"
                >
                    <option value="seo">SEO</option>
                    <option value="click">Clickbait Halus</option>
                    <option value="authority">Authority</option>
                    <option value="listicle">Listicle</option>
                </select>
            </label>
            <label class="block text-sm">
                <span class="mb-1 block font-semibold text-slate-700"
                    >Jumlah Headline</span
                >
                <input
                    id="headlineCount"
                    type="number"
                    min="1"
                    max="30"
                    value="12"
                    class="w-full rounded-2xl border border-slate-300 p-2"
                />
            </label>
            <label
                class="mt-6 inline-flex items-center gap-2 text-sm text-slate-700 md:mt-7"
            >
                <input
                    id="headlineWithYear"
                    type="checkbox"
                    class="h-4 w-4"
                    checked
                />
                Tambah tahun otomatis
            </label>
        </div>

        <div class="mt-4 flex flex-wrap gap-2">
            <button
                id="headlineGenerateBtn"
                class="rounded-xl bg-teal-600 px-4 py-2 text-sm font-semibold text-white hover:bg-teal-700"
            >
                Generate Headline
            </button>
            <button
                id="headlineCopyBtn"
                class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100"
            >
                Copy Output
            </button>
        </div>

        <textarea
            id="headlineOutput"
            class="mt-3 h-72 w-full rounded-2xl border border-slate-300 p-3 text-sm"
            readonly></textarea>
        <p id="headlineMessage" class="mt-2 text-sm text-slate-600"></p>
    </section>

    <script>
        const topicEl = document.getElementById(
            "headlineTopic",
        ) as HTMLInputElement | null;
        const keywordEl = document.getElementById(
            "headlineKeyword",
        ) as HTMLInputElement | null;
        const audienceEl = document.getElementById(
            "headlineAudience",
        ) as HTMLInputElement | null;
        const styleEl = document.getElementById(
            "headlineStyle",
        ) as HTMLSelectElement | null;
        const countEl = document.getElementById(
            "headlineCount",
        ) as HTMLInputElement | null;
        const yearEl = document.getElementById(
            "headlineWithYear",
        ) as HTMLInputElement | null;
        const outputEl = document.getElementById(
            "headlineOutput",
        ) as HTMLTextAreaElement | null;
        const messageEl = document.getElementById(
            "headlineMessage",
        ) as HTMLParagraphElement | null;

        const year = new Date().getFullYear();

        const templates: Record<string, string[]> = {
            seo: [
                "{topic} untuk {audience}: panduan lengkap {year}",
                "Cara {topic} paling efektif untuk {audience}",
                "{keyword}: strategi {topic} yang wajib dicoba",
                "Panduan {topic} dari nol sampai mahir",
            ],
            click: [
                "Banyak yang belum tahu: {topic} ini bisa bikin hasil naik cepat",
                "Cuma 10 menit, {topic} ini bikin kamu lebih unggul",
                "Rahasia {topic} yang sering dipakai praktisi",
                "Jangan lakukan {topic} sebelum baca ini",
            ],
            authority: [
                "Framework praktis {topic} untuk {audience}",
                "Best practice {topic}: checklist implementasi",
                "Metode terukur untuk optimasi {topic}",
                "Standar profesional dalam {topic}",
            ],
            listicle: [
                "7 cara {topic} untuk {audience}",
                "11 kesalahan umum saat {topic} dan cara menghindarinya",
                "9 ide {topic} yang bisa langsung dipraktikkan",
                "5 template {topic} siap pakai",
            ],
        };

        const fillTemplate = (template: string, data: Record<string, string>) =>
            template.replace(/\{(\w+)\}/g, (_, key: string) => data[key] ?? "");

        document
            .getElementById("headlineGenerateBtn")
            ?.addEventListener("click", () => {
                const topic = (topicEl?.value ?? "").trim();
                if (!topic) {
                    if (messageEl) messageEl.textContent = "Topik wajib diisi.";
                    return;
                }

                const keyword = (keywordEl?.value ?? topic).trim();
                const audience = (audienceEl?.value ?? "pemula").trim();
                const style = styleEl?.value ?? "seo";
                const count = Math.min(
                    30,
                    Math.max(1, Number(countEl?.value ?? 12)),
                );
                const withYear = yearEl?.checked ?? true;

                const rows = Array.from({ length: count }, (_, idx) => {
                    const template =
                        templates[style][idx % templates[style].length];
                    const item = fillTemplate(template, {
                        topic,
                        keyword,
                        audience,
                        year: withYear ? String(year) : "",
                    })
                        .replace(/\s+/g, " ")
                        .trim();
                    return `${idx + 1}. ${item}`;
                });

                if (outputEl) outputEl.value = rows.join("\n");
                if (messageEl)
                    messageEl.textContent = `${count} headline berhasil dibuat.`;
            });

        document
            .getElementById("headlineCopyBtn")
            ?.addEventListener("click", async () => {
                const text = outputEl?.value ?? "";
                if (!text) return;
                await navigator.clipboard.writeText(text);
                if (messageEl) messageEl.textContent = "Headline tersalin.";
            });
    </script>
</BaseLayout>
