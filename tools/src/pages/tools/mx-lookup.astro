---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
    title="MX Lookup - Irwansyah Tools"
    description="Cek MX record domain dengan DNS over HTTPS untuk validasi konfigurasi email server dan routing mail."
    canonicalPath="/tools/mx-lookup"
>
    <section
        class="rounded-3xl border border-slate-200 bg-white p-4 shadow-sm md:p-5"
    >
        <h1 class="text-2xl font-black text-slate-900 md:text-3xl">
            MX Lookup
        </h1>
        <p class="mt-1 text-sm text-slate-600">
            Lookup MX record domain untuk cek mail exchanger dan priority.
        </p>

        <div class="mt-3 grid gap-3 md:grid-cols-[minmax(0,1fr)_220px]">
            <input
                id="mxDomain"
                type="text"
                class="w-full rounded-2xl border border-slate-300 p-3 font-mono text-sm"
                placeholder="contoh: gmail.com"
            />
            <select
                id="mxProvider"
                class="rounded-2xl border border-slate-300 p-3 text-sm"
            >
                <option value="cloudflare">Cloudflare DNS</option>
                <option value="google">Google DNS</option>
            </select>
        </div>

        <div class="mt-3 flex flex-wrap gap-2">
            <button
                id="mxLookupBtn"
                class="rounded-xl bg-teal-600 px-4 py-2 text-sm font-semibold text-white hover:bg-teal-700"
                >Lookup MX</button
            >
            <button
                id="mxSampleBtn"
                class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100"
                >Use Sample</button
            >
            <button
                id="mxCopyJsonBtn"
                class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100"
                >Copy JSON</button
            >
            <button
                id="mxExportTxtBtn"
                class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100"
                >Export .txt</button
            >
        </div>

        <p id="mxMessage" class="mt-3 text-sm text-slate-600"></p>
        <pre
            id="mxOutput"
            class="mt-3 overflow-x-auto rounded-2xl border border-slate-200 bg-slate-50 p-3 font-mono text-xs text-slate-700">
        </pre>
    </section>

    <script>
        const domainEl = document.getElementById(
            "mxDomain",
        ) as HTMLInputElement | null;
        const providerEl = document.getElementById(
            "mxProvider",
        ) as HTMLSelectElement | null;
        const messageEl = document.getElementById(
            "mxMessage",
        ) as HTMLParagraphElement | null;
        const outputEl = document.getElementById(
            "mxOutput",
        ) as HTMLPreElement | null;
        let lastResult: unknown = null;

        const downloadTxt = (filename: string, text: string) => {
            const blob = new Blob([text], { type: "text/plain;charset=utf-8" });
            const url = URL.createObjectURL(blob);
            const link = document.createElement("a");
            link.href = url;
            link.download = filename;
            link.click();
            URL.revokeObjectURL(url);
        };

        const resolveDnsJson = async (
            domain: string,
            type: string,
            provider: string,
        ) => {
            const endpoint =
                provider === "google"
                    ? `https://dns.google/resolve?name=${encodeURIComponent(domain)}&type=${encodeURIComponent(type)}`
                    : `https://cloudflare-dns.com/dns-query?name=${encodeURIComponent(domain)}&type=${encodeURIComponent(type)}`;

            const res = await fetch(endpoint, {
                headers: { Accept: "application/dns-json" },
            });
            if (!res.ok) throw new Error(`DNS request gagal (${res.status})`);
            return await res.json();
        };

        const runLookup = async () => {
            try {
                const domain = (domainEl?.value ?? "").trim().toLowerCase();
                const provider = providerEl?.value ?? "cloudflare";
                if (!domain) {
                    if (messageEl)
                        messageEl.textContent = "Domain wajib diisi.";
                    return;
                }

                if (messageEl) messageEl.textContent = "Memproses MX lookup...";
                const data = await resolveDnsJson(domain, "MX", provider);
                lastResult = data;
                const answers = (data.Answer ?? []) as Array<{
                    data?: string;
                    TTL?: number;
                }>;

                if (answers.length === 0) {
                    if (outputEl)
                        outputEl.textContent = "MX record tidak ditemukan.";
                    if (messageEl)
                        messageEl.textContent =
                            "Lookup selesai. Tidak ada MX record.";
                    return;
                }

                const lines = answers.map(
                    (item, index) =>
                        `#${index + 1} ${item.data ?? ""} TTL=${item.TTL ?? "-"}`,
                );
                if (outputEl) outputEl.textContent = lines.join("\n");
                if (messageEl)
                    messageEl.textContent = `Lookup selesai. Ditemukan ${answers.length} MX record.`;
            } catch (error) {
                if (outputEl) outputEl.textContent = "";
                if (messageEl)
                    messageEl.textContent = `Gagal lookup MX: ${error instanceof Error ? error.message : "Unknown error"}`;
            }
        };

        document
            .getElementById("mxLookupBtn")
            ?.addEventListener("click", runLookup);
        document
            .getElementById("mxSampleBtn")
            ?.addEventListener("click", () => {
                if (domainEl) domainEl.value = "gmail.com";
                runLookup();
            });
        document
            .getElementById("mxCopyJsonBtn")
            ?.addEventListener("click", async () => {
                if (!lastResult) return;
                await navigator.clipboard.writeText(
                    JSON.stringify(lastResult, null, 2),
                );
                if (messageEl)
                    messageEl.textContent =
                        "JSON hasil lookup tersalin ke clipboard.";
            });
        document
            .getElementById("mxExportTxtBtn")
            ?.addEventListener("click", () => {
                const domain = (domainEl?.value ?? "lookup").trim() || "lookup";
                const output = outputEl?.textContent?.trim() ?? "";
                if (!output) return;
                downloadTxt(`mx-lookup-${domain}.txt`, output);
                if (messageEl)
                    messageEl.textContent =
                        "Hasil lookup berhasil diexport ke .txt.";
            });
    </script>
</BaseLayout>
