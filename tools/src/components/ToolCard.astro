---
interface Props {
  title: string;
  description: string;
  href: string;
  status?: string;
}

const { title, description, href, status = "Ready" } = Astro.props;
---

<a
  href={href}
  class="group block rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-xl"
>
  <p class="text-xs font-semibold uppercase tracking-[0.14em] text-teal-600">{status}</p>
  <h3 class="mt-3 text-2xl font-bold text-slate-900">{title}</h3>
  <p class="mt-2 text-sm leading-relaxed text-slate-600">{description}</p>
  <p class="mt-6 text-sm font-semibold text-amber-700 group-hover:text-amber-800">Open tool -></p>
</a>
