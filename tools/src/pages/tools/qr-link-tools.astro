---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
    title="QR & Link Tools - Irwansyah Tools"
    description="Generator QR code, UTM URL builder, URL parser, dan copy/download QR untuk campaign marketing."
    canonicalPath="/tools/qr-link-tools"
>
    <section
        class="rounded-3xl border border-slate-200 bg-white p-4 shadow-sm md:p-5"
    >
        <h1 class="text-2xl font-black text-slate-900 md:text-3xl">
            QR / Link Tools
        </h1>
        <p class="mt-1 text-sm text-slate-600">
            Bangun link campaign (UTM), buat QR code, dan cek struktur URL dalam
            satu halaman.
        </p>

        <div class="mt-4 rounded-2xl border border-slate-200 bg-slate-50 p-3">
            <p class="text-sm font-bold text-slate-800">UTM Builder</p>
            <div class="mt-2 grid gap-3 md:grid-cols-2">
                <label class="block text-sm md:col-span-2">
                    <span class="mb-1 block font-semibold text-slate-700"
                        >Base URL</span
                    >
                    <input
                        id="utmBaseUrl"
                        type="url"
                        placeholder="https://example.com/landing"
                        class="w-full rounded-xl border border-slate-300 p-2"
                    />
                </label>
                <label class="block text-sm"
                    ><span class="mb-1 block font-semibold text-slate-700"
                        >utm_source</span
                    ><input
                        id="utmSource"
                        type="text"
                        placeholder="instagram"
                        class="w-full rounded-xl border border-slate-300 p-2"
                    /></label
                >
                <label class="block text-sm"
                    ><span class="mb-1 block font-semibold text-slate-700"
                        >utm_medium</span
                    ><input
                        id="utmMedium"
                        type="text"
                        placeholder="social"
                        class="w-full rounded-xl border border-slate-300 p-2"
                    /></label
                >
                <label class="block text-sm"
                    ><span class="mb-1 block font-semibold text-slate-700"
                        >utm_campaign</span
                    ><input
                        id="utmCampaign"
                        type="text"
                        placeholder="ramadhan_sale"
                        class="w-full rounded-xl border border-slate-300 p-2"
                    /></label
                >
                <label class="block text-sm"
                    ><span class="mb-1 block font-semibold text-slate-700"
                        >utm_content</span
                    ><input
                        id="utmContent"
                        type="text"
                        placeholder="feed_banner"
                        class="w-full rounded-xl border border-slate-300 p-2"
                    /></label
                >
            </div>
            <div class="mt-3 flex flex-wrap gap-2">
                <button
                    id="utmBuildBtn"
                    class="rounded-xl bg-teal-600 px-4 py-2 text-sm font-semibold text-white hover:bg-teal-700"
                    >Build UTM URL</button
                >
                <button
                    id="utmCopyBtn"
                    class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100"
                    >Copy URL</button
                >
            </div>
        </div>

        <label class="mt-4 block text-sm">
            <span class="mb-1 block font-semibold text-slate-700"
                >Target URL / Text untuk QR</span
            >
            <textarea
                id="qrInput"
                class="h-28 w-full rounded-2xl border border-slate-300 p-3 text-sm"
                placeholder="Masukkan URL atau teks..."></textarea>
        </label>

        <div class="mt-3 grid gap-3 md:grid-cols-3">
            <label class="block text-sm">
                <span class="mb-1 block font-semibold text-slate-700"
                    >Ukuran QR</span
                >
                <input
                    id="qrSize"
                    type="number"
                    min="120"
                    max="1024"
                    value="320"
                    class="w-full rounded-2xl border border-slate-300 p-2"
                />
            </label>
            <label class="block text-sm">
                <span class="mb-1 block font-semibold text-slate-700"
                    >Margin</span
                >
                <input
                    id="qrMargin"
                    type="number"
                    min="0"
                    max="10"
                    value="2"
                    class="w-full rounded-2xl border border-slate-300 p-2"
                />
            </label>
            <label class="block text-sm">
                <span class="mb-1 block font-semibold text-slate-700"
                    >Error Correction</span
                >
                <select
                    id="qrLevel"
                    class="w-full rounded-2xl border border-slate-300 p-2"
                >
                    <option value="L">L</option>
                    <option value="M" selected>M</option>
                    <option value="Q">Q</option>
                    <option value="H">H</option>
                </select>
            </label>
        </div>

        <div class="mt-4 flex flex-wrap gap-2">
            <button
                id="qrGenerateBtn"
                class="rounded-xl bg-teal-600 px-4 py-2 text-sm font-semibold text-white hover:bg-teal-700"
                >Generate QR</button
            >
            <a
                id="qrDownloadBtn"
                class="hidden rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100"
                download="qr-code.png">Download QR</a
            >
        </div>

        <p id="qrMessage" class="mt-2 text-sm text-slate-600"></p>

        <div class="mt-3 grid gap-3 md:grid-cols-2">
            <div class="rounded-2xl border border-slate-200 bg-slate-50 p-3">
                <p class="text-sm font-bold text-slate-800">QR Preview</p>
                <div
                    id="qrCanvasWrap"
                    class="mt-2 flex min-h-[340px] items-center justify-center rounded-xl border border-slate-200 bg-white p-3"
                >
                </div>
            </div>
            <div class="rounded-2xl border border-slate-200 bg-slate-50 p-3">
                <p class="text-sm font-bold text-slate-800">URL Insights</p>
                <pre
                    id="urlInsight"
                    class="mt-2 whitespace-pre-wrap rounded-xl border border-slate-200 bg-white p-3 text-xs text-slate-700">
                </pre>
            </div>
        </div>
    </section>

    <script src="https://cdn.jsdelivr.net/npm/qrcode/build/qrcode.min.js"
    ></script>
    <script>
        const baseEl = document.getElementById(
            "utmBaseUrl",
        ) as HTMLInputElement | null;
        const sourceEl = document.getElementById(
            "utmSource",
        ) as HTMLInputElement | null;
        const mediumEl = document.getElementById(
            "utmMedium",
        ) as HTMLInputElement | null;
        const campaignEl = document.getElementById(
            "utmCampaign",
        ) as HTMLInputElement | null;
        const contentEl = document.getElementById(
            "utmContent",
        ) as HTMLInputElement | null;
        const qrInputEl = document.getElementById(
            "qrInput",
        ) as HTMLTextAreaElement | null;
        const sizeEl = document.getElementById(
            "qrSize",
        ) as HTMLInputElement | null;
        const marginEl = document.getElementById(
            "qrMargin",
        ) as HTMLInputElement | null;
        const levelEl = document.getElementById(
            "qrLevel",
        ) as HTMLSelectElement | null;
        const wrapEl = document.getElementById(
            "qrCanvasWrap",
        ) as HTMLDivElement | null;
        const messageEl = document.getElementById(
            "qrMessage",
        ) as HTMLParagraphElement | null;
        const insightEl = document.getElementById(
            "urlInsight",
        ) as HTMLPreElement | null;
        const downloadEl = document.getElementById(
            "qrDownloadBtn",
        ) as HTMLAnchorElement | null;

        const parseInsight = (raw: string) => {
            try {
                const url = new URL(raw);
                const params = Array.from(url.searchParams.entries());
                const lines = [
                    `Origin: ${url.origin}`,
                    `Path: ${url.pathname || "/"}`,
                    `Hash: ${url.hash || "-"}`,
                    `Jumlah Query Param: ${params.length}`,
                ];
                params.forEach(([key, value]) =>
                    lines.push(`- ${key} = ${value}`),
                );
                if (insightEl) insightEl.textContent = lines.join("\n");
            } catch {
                if (insightEl) {
                    insightEl.textContent =
                        "Input bukan URL valid. Tetap bisa dipakai untuk QR text biasa.";
                }
            }
        };

        const buildUtmUrl = () => {
            const raw = (baseEl?.value ?? "").trim();
            if (!raw) {
                if (messageEl) messageEl.textContent = "Base URL wajib diisi.";
                return "";
            }
            let url: URL;
            try {
                url = new URL(raw);
            } catch {
                if (messageEl) messageEl.textContent = "Base URL tidak valid.";
                return "";
            }
            const entries: [string, string][] = [
                ["utm_source", (sourceEl?.value ?? "").trim()],
                ["utm_medium", (mediumEl?.value ?? "").trim()],
                ["utm_campaign", (campaignEl?.value ?? "").trim()],
                ["utm_content", (contentEl?.value ?? "").trim()],
            ];
            entries.forEach(([key, value]) => {
                if (value) url.searchParams.set(key, value);
            });
            return url.toString();
        };

        const renderQr = async (rawValue: string) => {
            const qrLib = (
                window as unknown as {
                    QRCode?: { toCanvas: (...args: unknown[]) => void };
                }
            ).QRCode;
            if (!qrLib || !wrapEl) {
                if (messageEl)
                    messageEl.textContent =
                        "Library QR belum siap. Coba beberapa detik lagi.";
                return;
            }

            const value = rawValue.trim();
            if (!value) {
                if (messageEl)
                    messageEl.textContent = "Isi URL atau teks terlebih dulu.";
                return;
            }

            const size = Math.min(
                1024,
                Math.max(120, Number(sizeEl?.value ?? 320)),
            );
            const margin = Math.min(
                10,
                Math.max(0, Number(marginEl?.value ?? 2)),
            );
            const level = (levelEl?.value ?? "M") as "L" | "M" | "Q" | "H";

            wrapEl.innerHTML = "";
            const canvas = document.createElement("canvas");
            wrapEl.appendChild(canvas);

            await new Promise<void>((resolve, reject) => {
                qrLib.toCanvas(
                    canvas,
                    value,
                    {
                        width: size,
                        margin,
                        errorCorrectionLevel: level,
                        color: {
                            dark: "#0f172a",
                            light: "#ffffff",
                        },
                    },
                    (err?: Error) => {
                        if (err) reject(err);
                        else resolve();
                    },
                );
            });

            if (downloadEl) {
                downloadEl.href = canvas.toDataURL("image/png");
                downloadEl.classList.remove("hidden");
            }
            parseInsight(value);
            if (messageEl) messageEl.textContent = "QR code berhasil dibuat.";
        };

        document
            .getElementById("utmBuildBtn")
            ?.addEventListener("click", () => {
                const built = buildUtmUrl();
                if (!built) return;
                if (qrInputEl) qrInputEl.value = built;
                parseInsight(built);
                if (messageEl)
                    messageEl.textContent = "UTM URL berhasil dibuat.";
            });

        document
            .getElementById("utmCopyBtn")
            ?.addEventListener("click", async () => {
                const value = (qrInputEl?.value ?? "").trim();
                if (!value) return;
                await navigator.clipboard.writeText(value);
                if (messageEl)
                    messageEl.textContent = "URL tersalin ke clipboard.";
            });

        document
            .getElementById("qrGenerateBtn")
            ?.addEventListener("click", async () => {
                try {
                    await renderQr(qrInputEl?.value ?? "");
                } catch {
                    if (messageEl)
                        messageEl.textContent = "Gagal membuat QR code.";
                }
            });
    </script>
</BaseLayout>
