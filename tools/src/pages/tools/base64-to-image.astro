---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Base64 to Image Converter - Irwansyah Tools"
  description="Konversi Base64 image menjadi preview PNG/JPG/WEBP dan download file hasilnya."
  canonicalPath="/tools/base64-to-image"
>
  <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm md:p-8">
    <h1 class="text-3xl font-black text-slate-900">Base64 to Image</h1>
    <p class="mt-2 text-sm text-slate-600">Paste data URI atau raw Base64 untuk preview gambar.</p>

    <label class="mt-6 block">
      <span class="mb-2 block text-sm font-semibold text-slate-700">Base64 Input</span>
      <textarea id="imageBase64Input" class="h-56 w-full rounded-2xl border border-slate-300 p-3 font-mono text-sm" placeholder="data:image/png;base64,iVBORw0KGgoAAA..."></textarea>
    </label>

    <div class="mt-4 flex flex-wrap gap-2">
      <button id="renderImageBtn" class="rounded-xl bg-teal-600 px-4 py-2 text-sm font-semibold text-white hover:bg-teal-700">Render Image</button>
      <a id="downloadImageBtn" class="hidden rounded-xl bg-amber-500 px-4 py-2 text-sm font-semibold text-slate-900 hover:bg-amber-400" download="converted-image.png">Download Image</a>
    </div>

    <p id="imageMessage" class="mt-3 text-sm text-slate-600"></p>

    <div class="mt-6 rounded-2xl border border-slate-200 bg-slate-50 p-4">
      <img id="imagePreview" alt="Image preview" class="mx-auto hidden max-h-[420px] rounded-xl object-contain" />
    </div>
  </section>

  <script>
    const inputEl = document.getElementById("imageBase64Input");
    const previewEl = document.getElementById("imagePreview");
    const messageEl = document.getElementById("imageMessage");
    const downloadEl = document.getElementById("downloadImageBtn");

    const detectMime = (value) => {
      if (value.startsWith("data:image/")) {
        const match = value.match(/^data:(image\/[a-zA-Z0-9.+-]+);base64,/);
        return match?.[1] ?? "image/png";
      }
      return "image/png";
    };

    document.getElementById("renderImageBtn")?.addEventListener("click", () => {
      const raw = inputEl?.value.trim() ?? "";
      if (!raw) {
        messageEl.textContent = "Input Base64 masih kosong.";
        previewEl.classList.add("hidden");
        downloadEl.classList.add("hidden");
        return;
      }

      const mime = detectMime(raw);
      const dataUri = raw.startsWith("data:image/") ? raw : `data:${mime};base64,${raw}`;

      previewEl.src = dataUri;
      previewEl.classList.remove("hidden");
      downloadEl.href = dataUri;
      downloadEl.download = `converted-image.${mime.split("/")[1] || "png"}`;
      downloadEl.classList.remove("hidden");
      messageEl.textContent = `Preview siap (${mime}).`;
    });
  </script>
</BaseLayout>
