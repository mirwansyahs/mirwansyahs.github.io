---
interface Props {
  title: string;
  description: string;
  href: string;
  status?: string;
  category?: string;
}

const {
  title,
  description,
  href,
  status = "Ready",
  category = "General",
} = Astro.props;
---

<a
  href={href}
  data-tool-title={title}
  data-category={category}
  class="group block rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-xl"
>
  <div class="flex flex-wrap items-center gap-2">
    <p class="text-xs font-semibold uppercase tracking-[0.14em] text-teal-600">
      {status}
    </p>
    <span
      class="rounded-full bg-slate-100 px-2 py-0.5 text-[11px] font-semibold uppercase tracking-[0.08em] text-slate-700"
      >{category}</span
    >
  </div>
  <h3 class="mt-3 text-2xl font-bold text-slate-900">{title}</h3>
  <p class="mt-2 text-sm leading-relaxed text-slate-600">{description}</p>
  <p
    class="mt-6 text-sm font-semibold text-amber-700 group-hover:text-amber-800"
  >
    Open tool ->
  </p>
</a>
