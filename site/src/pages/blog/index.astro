---
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import MainLayout from '../../layouts/MainLayout.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<MainLayout title="Blog | Irwansyah" description="Artikel original seputar web, mobile, produk digital, dan optimasi SEO.">
	<section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm md:p-8">
		<p class="text-xs font-bold uppercase tracking-[0.16em] text-teal-700">Knowledge Base</p>
		<h1 class="mt-2 text-3xl font-black text-slate-900 md:text-4xl">Blog</h1>
		<p class="mt-3 max-w-3xl text-slate-600">Kumpulan artikel original dari pengalaman membangun aplikasi, tools, dan proses pengembangan produk digital.</p>

		<div class="mt-6 grid gap-4 md:grid-cols-2">
			{
				posts.map((post) => (
					<a href={`/blog/${post.id}/`} class="rounded-2xl border border-slate-200 p-4 transition hover:-translate-y-0.5 hover:shadow-md">
						<p class="text-xs font-semibold uppercase tracking-[0.12em] text-slate-500">
							<FormattedDate date={post.data.pubDate} />
						</p>
						<h2 class="mt-2 text-xl font-bold text-slate-900">{post.data.title}</h2>
						<p class="mt-2 text-sm leading-relaxed text-slate-600">{post.data.description}</p>
					</a>
				))
			}
		</div>
	</section>
</MainLayout>
