---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
    title="UUID Generator - Irwansyah Tools"
    description="Generate UUID v4 secara instan untuk database key, request tracking, dan ID unik aplikasi web maupun backend."
    canonicalPath="/tools/uuid-generator"
>
    <section
        class="rounded-3xl border border-slate-200 bg-white p-4 shadow-sm md:p-5"
    >
        <h1 class="text-2xl font-black text-slate-900 md:text-3xl">
            UUID Generator
        </h1>
        <p class="mt-1 text-sm text-slate-600">
            Buat UUID v4 sekali klik, pilih jumlah output, lalu copy hasilnya.
        </p>

        <div class="mt-3 grid gap-3 md:grid-cols-[220px_1fr]">
            <label class="block">
                <span class="mb-2 block text-sm font-semibold text-slate-700"
                    >Jumlah UUID</span
                >
                <input
                    id="uuidCount"
                    type="number"
                    min="1"
                    max="200"
                    value="5"
                    class="w-full rounded-2xl border border-slate-300 p-3 text-sm"
                />
            </label>
            <div class="flex items-end gap-2">
                <button
                    id="uuidGenerateBtn"
                    class="rounded-xl bg-teal-600 px-4 py-2 text-sm font-semibold text-white hover:bg-teal-700"
                    >Generate</button
                >
                <button
                    id="uuidCopyBtn"
                    class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100"
                    >Copy Output</button
                >
            </div>
        </div>

        <textarea
            id="uuidOutput"
            class="mt-3 h-56 w-full rounded-2xl border border-slate-300 p-3 font-mono text-xs"
            readonly></textarea>
        <p id="uuidMessage" class="mt-2 text-sm text-slate-600"></p>
    </section>

    <script>
        const countEl = document.getElementById(
            "uuidCount",
        ) as HTMLInputElement | null;
        const outputEl = document.getElementById(
            "uuidOutput",
        ) as HTMLTextAreaElement | null;
        const messageEl = document.getElementById(
            "uuidMessage",
        ) as HTMLParagraphElement | null;

        const createUuidV4 = () => {
            if (
                typeof crypto !== "undefined" &&
                typeof crypto.randomUUID === "function"
            ) {
                return crypto.randomUUID();
            }

            const bytes = new Uint8Array(16);
            crypto.getRandomValues(bytes);
            bytes[6] = (bytes[6] & 0x0f) | 0x40;
            bytes[8] = (bytes[8] & 0x3f) | 0x80;
            const hex = [...bytes].map((b) => b.toString(16).padStart(2, "0"));
            return `${hex.slice(0, 4).join("")}-${hex.slice(4, 6).join("")}-${hex.slice(6, 8).join("")}-${hex.slice(8, 10).join("")}-${hex.slice(10, 16).join("")}`;
        };

        document
            .getElementById("uuidGenerateBtn")
            ?.addEventListener("click", () => {
                const count = Math.min(
                    200,
                    Math.max(1, Number(countEl?.value ?? 1)),
                );
                const lines = Array.from({ length: count }, () =>
                    createUuidV4(),
                );
                if (outputEl) outputEl.value = lines.join("\n");
                if (messageEl)
                    messageEl.textContent = `${count} UUID berhasil dibuat.`;
            });

        document
            .getElementById("uuidCopyBtn")
            ?.addEventListener("click", async () => {
                const value = outputEl?.value ?? "";
                if (!value) return;
                await navigator.clipboard.writeText(value);
                if (messageEl)
                    messageEl.textContent =
                        "Output UUID tersalin ke clipboard.";
            });
    </script>
</BaseLayout>
