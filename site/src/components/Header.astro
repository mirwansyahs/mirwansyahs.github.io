---
import { NAV_LINKS, SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="border-b border-slate-200/70 bg-white/85 backdrop-blur">
  <nav class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-4 px-4 py-4 md:px-8">
    <a href="/" class="text-lg font-black tracking-tight text-slate-900">{SITE_TITLE}</a>
    <div class="flex flex-wrap items-center gap-2 text-sm">
      {
        NAV_LINKS.map((item) => (
          <HeaderLink
            href={item.href}
            class="rounded-full px-3 py-2 font-semibold text-slate-700 transition hover:bg-slate-100 hover:text-slate-900"
          >
            {item.label}
          </HeaderLink>
        ))
      }
    </div>
  </nav>
</header>
