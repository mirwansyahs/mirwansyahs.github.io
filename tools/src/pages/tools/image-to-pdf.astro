---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
    title="Image to PDF - Irwansyah Tools"
    description="Konversi satu atau banyak gambar menjadi PDF langsung di browser tanpa upload ke server."
    canonicalPath="/tools/image-to-pdf"
>
    <section
        class="rounded-3xl border border-slate-200 bg-white p-4 shadow-sm md:p-5"
    >
        <h1 class="text-2xl font-black text-slate-900 md:text-3xl">
            Image to PDF
        </h1>
        <p class="mt-1 text-sm text-slate-600">
            Gabungkan gambar ke PDF. Mendukung multi-file dan urutan upload.
        </p>

        <input
            id="imgPdfInput"
            type="file"
            accept="image/*"
            multiple
            class="mt-3 block w-full rounded-2xl border border-slate-300 bg-white p-2 text-sm text-slate-700 file:mr-3 file:rounded-xl file:border-0 file:bg-teal-600 file:px-4 file:py-2 file:font-semibold file:text-white hover:file:bg-teal-700"
        />

        <div class="mt-3 grid gap-3 md:grid-cols-3">
            <label class="block text-sm">
                <span class="mb-1 block font-semibold text-slate-700"
                    >Orientation</span
                >
                <select
                    id="imgPdfOrientation"
                    class="w-full rounded-2xl border border-slate-300 p-2"
                >
                    <option value="portrait">Portrait</option>
                    <option value="landscape">Landscape</option>
                </select>
            </label>
            <label class="block text-sm">
                <span class="mb-1 block font-semibold text-slate-700"
                    >Margin (pt)</span
                >
                <input
                    id="imgPdfMargin"
                    type="number"
                    min="0"
                    value="24"
                    class="w-full rounded-2xl border border-slate-300 p-2"
                />
            </label>
            <label class="block text-sm">
                <span class="mb-1 block font-semibold text-slate-700"
                    >Image Quality</span
                >
                <input
                    id="imgPdfQuality"
                    type="range"
                    min="0.5"
                    max="1"
                    step="0.05"
                    value="0.85"
                    class="w-full"
                />
            </label>
        </div>

        <button
            id="imgPdfRunBtn"
            class="mt-3 rounded-xl bg-teal-600 px-4 py-2 text-sm font-semibold text-white hover:bg-teal-700"
            >Convert to PDF</button
        >
        <p id="imgPdfMessage" class="mt-3 text-sm text-slate-600"></p>
        <a
            id="imgPdfDownload"
            class="mt-3 hidden inline-flex rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100"
            download="images.pdf">Download PDF</a
        >
    </section>

    <script src="https://cdn.jsdelivr.net/npm/jspdf@2.5.2/dist/jspdf.umd.min.js"
    ></script>
    <script>
        const inputEl = document.getElementById(
            "imgPdfInput",
        ) as HTMLInputElement | null;
        const orientationEl = document.getElementById(
            "imgPdfOrientation",
        ) as HTMLSelectElement | null;
        const marginEl = document.getElementById(
            "imgPdfMargin",
        ) as HTMLInputElement | null;
        const qualityEl = document.getElementById(
            "imgPdfQuality",
        ) as HTMLInputElement | null;
        const messageEl = document.getElementById(
            "imgPdfMessage",
        ) as HTMLParagraphElement | null;
        const downloadEl = document.getElementById(
            "imgPdfDownload",
        ) as HTMLAnchorElement | null;

        const readAsDataUrl = (file: File) =>
            new Promise<string>((resolve, reject) => {
                const reader = new FileReader();
                reader.onload = () => resolve(String(reader.result ?? ""));
                reader.onerror = () =>
                    reject(reader.error ?? new Error("Read error"));
                reader.readAsDataURL(file);
            });

        const loadImage = (src: string) =>
            new Promise<HTMLImageElement>((resolve, reject) => {
                const img = new Image();
                img.onload = () => resolve(img);
                img.onerror = () => reject(new Error("Gagal memuat gambar."));
                img.src = src;
            });

        document
            .getElementById("imgPdfRunBtn")
            ?.addEventListener("click", async () => {
                try {
                    const files = Array.from(inputEl?.files ?? []);
                    if (files.length === 0) {
                        if (messageEl)
                            messageEl.textContent =
                                "Silakan pilih minimal satu gambar.";
                        return;
                    }

                    const jsPdfApi = (window as any).jspdf;
                    if (!jsPdfApi?.jsPDF)
                        throw new Error("Library jsPDF belum siap.");

                    if (messageEl)
                        messageEl.textContent =
                            "Memproses konversi image ke PDF...";

                    const orientation = (orientationEl?.value ?? "portrait") as
                        | "portrait"
                        | "landscape";
                    const margin = Math.max(0, Number(marginEl?.value ?? 24));
                    const quality = Number(qualityEl?.value ?? 0.85);
                    const pdf = new jsPdfApi.jsPDF({
                        orientation,
                        unit: "pt",
                        format: "a4",
                    });

                    const pageWidth = pdf.internal.pageSize.getWidth();
                    const pageHeight = pdf.internal.pageSize.getHeight();
                    const usableWidth = pageWidth - margin * 2;
                    const usableHeight = pageHeight - margin * 2;

                    for (let i = 0; i < files.length; i += 1) {
                        if (i > 0) pdf.addPage();

                        const dataUrl = await readAsDataUrl(files[i]);
                        const image = await loadImage(dataUrl);
                        const ratio = Math.min(
                            usableWidth / image.width,
                            usableHeight / image.height,
                        );
                        const drawWidth = image.width * ratio;
                        const drawHeight = image.height * ratio;
                        const x = (pageWidth - drawWidth) / 2;
                        const y = (pageHeight - drawHeight) / 2;

                        const tempCanvas = document.createElement("canvas");
                        tempCanvas.width = image.width;
                        tempCanvas.height = image.height;
                        const tempCtx = tempCanvas.getContext("2d");
                        if (!tempCtx)
                            throw new Error("Canvas context tidak tersedia.");
                        tempCtx.drawImage(image, 0, 0);

                        const jpgData = tempCanvas.toDataURL(
                            "image/jpeg",
                            quality,
                        );
                        pdf.addImage(
                            jpgData,
                            "JPEG",
                            x,
                            y,
                            drawWidth,
                            drawHeight,
                        );
                    }

                    const blob = pdf.output("blob");
                    const url = URL.createObjectURL(blob);
                    if (downloadEl) {
                        downloadEl.href = url;
                        downloadEl.classList.remove("hidden");
                    }
                    if (messageEl)
                        messageEl.textContent = `Konversi selesai. Total ${files.length} gambar.`;
                } catch (error) {
                    if (messageEl)
                        messageEl.textContent = `Gagal convert image ke PDF: ${error instanceof Error ? error.message : "Unknown error"}`;
                }
            });
    </script>
</BaseLayout>
