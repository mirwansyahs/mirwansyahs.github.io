---
import BaseLayout from "../layouts/BaseLayout.astro";
import ToolCard from "../components/ToolCard.astro";
import { SITE } from "../config/site";
---

<BaseLayout title={SITE.title} description={SITE.description} canonicalPath="/">
	<section
		class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm md:p-10"
	>
		<p class="text-xs font-bold uppercase tracking-[0.16em] text-teal-700">
			SEO + Fast Utilities
		</p>
		<h1
			class="mt-4 text-4xl font-black leading-tight text-slate-900 md:text-5xl"
		>
			Developer Tools Cepat, Ringan, dan Bisa Diindeks Google
		</h1>
		<p class="mt-4 max-w-3xl text-base leading-relaxed text-slate-600">
			Fokus utama: JSON Viewer suite (unstringify, beautify, JSON ke XML,
			JSON ke CSV), plus tool Base64. Semua halaman memakai layout
			reusable agar perubahan global tidak perlu diedit satu per satu.
		</p>
	</section>

	<section class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
		<ToolCard
			title="JSON Viewer Suite"
			description="Parse JSON, unstringify JSON string, beautify output, convert to XML/CSV dalam satu halaman."
			href="/tools/json-viewer"
			status="Priority"
		/>
		<ToolCard
			title="Base64 Encode / Decode"
			description="Encode text ke Base64 dan decode kembali dengan cepat langsung di browser."
			href="/tools/base64-encode-decode"
		/>
		<ToolCard
			title="Base64 to Image"
			description="Render Base64 image (PNG/JPG/WEBP), preview, dan download hasil gambar."
			href="/tools/base64-to-image"
		/>
		<ToolCard
			title="AES Encrypt / Decrypt"
			description="Enkripsi-dekripsi dua arah (bukan hash) dengan AES-GCM langsung di browser."
			href="/tools/aes-encrypt-decrypt"
		/>
		<ToolCard
			title="Hash Generator"
			description="Generate hash one-way: MD5, SHA-1, SHA-256, SHA-384, SHA-512, plus info Tiger dan bcrypt."
			href="/tools/hash-generator"
		/>
	</section>
</BaseLayout>
